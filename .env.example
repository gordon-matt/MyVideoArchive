# Copy to .env and set real values. Do not commit .env.
# Used by: docker compose (and optionally by the app if you use a tool that loads .env)

# PostgreSQL password for the db service (default in compose is "postgres")
POSTGRES_PASSWORD=postgres

# Optional: override the app's connection string (e.g. for a remote DB).
# If not set, the app uses the value from docker-compose (Host=db; ...).
# ConnectionStrings__DefaultConnection=Host=db;Port=5432;Database=myvideoarchive;Username=postgres;Password=yourpassword
