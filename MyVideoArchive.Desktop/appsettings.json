{
  "SeedAdmin": {
    "Email": "admin@myvideoarchive.local"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Hangfire": "Information"
    }
  },
  "AllowedHosts": "*",
  "VideoDownload": {
    "OutputPath": "Downloads",
    "VideoQuality": "bestvideo[height=720]+bestaudio/bestvideo[height=720]+bestaudio/bestvideo[height=480]+bestaudio/best",
    "Throttle": {
      "MinDelaySeconds": 10,
      "MaxDelaySeconds": 60,
      "BatchSize": 25,
      "BatchWindowMinutes": 30
    }
  },
  "YoutubeDL": {
    "ExecutablePath": null,
    "FFmpegPath": null
  },
  "Tags": {
    "ImportTagsFromPlatform": false
  },
  "ConnectionStrings": {
    // Configure your database connection here, via User Secrets, or via the
    // ConnectionStrings__DefaultConnection environment variable. The desktop build
    // currently uses the same PostgreSQL provider as the web build.
    "DefaultConnection": ""
  }
}
