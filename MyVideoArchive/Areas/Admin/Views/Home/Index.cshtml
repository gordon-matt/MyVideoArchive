@using MyVideoArchive.Infrastructure
@inject IAuthProviderService AuthProvider
@{
    ViewData["Title"] = "Admin";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="~/css/admin-index.css" asp-append-version="true" />
}

<div class="row mb-4">
    <div class="col-12">
        <h2><i class="bi bi-gear-fill"></i> Admin</h2>
        <p class="text-muted">Administrative tools and utilities</p>
    </div>
</div>

<ul class="nav nav-tabs mb-4" id="adminTabs" role="tablist">
    <li class="nav-item" role="presentation">
        <button class="nav-link active" id="tools-tab" data-bs-toggle="tab" data-bs-target="#tools" type="button" role="tab">
            <i class="bi bi-tools"></i> Tools
        </button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link" id="tags-tab" data-bs-toggle="tab" data-bs-target="#tags" type="button" role="tab"
                data-bind="click: loadGlobalTags">
            <i class="bi bi-tags"></i> Tags
        </button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link" id="failed-tab" data-bs-toggle="tab" data-bs-target="#failed" type="button" role="tab"
                data-bind="click: loadFailedDownloads">
            <i class="bi bi-exclamation-triangle-fill text-danger"></i> Failed Downloads
            <!-- ko if: failedCount() > 0 -->
            <span class="badge bg-danger ms-1" data-bind="text: failedCount()"></span>
            <!-- /ko -->
        </button>
    </li>
    @if (!AuthProvider.IsKeycloak)
    {
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="users-tab" data-bs-toggle="tab" data-bs-target="#users" type="button" role="tab"
                    data-bind="click: loadUsersTab">
                <i class="bi bi-people"></i> Users
            </button>
        </li>
    }
</ul>

<div class="tab-content" id="adminTabsContent">

    <!-- ── Tools tab ──────────────────────────────────────────────────────── -->
    <div class="tab-pane fade show active" id="tools" role="tabpanel">
        <div class="row">
            <div class="col-12 col-lg-6">
                <div class="card mb-4">
                    <div class="card-header">
                        <h5 class="mb-0"><i class="bi bi-folder-symlink"></i> File System</h5>
                    </div>
                    <div class="card-body">
                        <p class="card-text text-muted">
                            Scan the configured downloads folder and reconcile video files with the database.
                            For non-Custom channels, checks convention paths (<code>OutputPath/{ChannelId}/{VideoId}</code>) for unlinked videos and detects files that no longer exist.
                            Custom channel files are enumerated from <code>OutputPath/_Custom/{ChannelId}/</code>.
                        </p>
                        <div id="scanStatus" class="alert d-none" role="alert"></div>

                        <div class="d-flex gap-2 align-items-center flex-wrap">
                            <button id="btnScanFileSystem" class="btn btn-primary"
                                    data-bind="click: scanFileSystem, enable: !scanning()">
                                <span data-bind="visible: !scanning()">
                                    <i class="bi bi-search"></i> Scan File System
                                </span>
                                <span data-bind="visible: scanning()" class="d-none">
                                    <i class="bi bi-search"></i> Scan File System
                                </span>
                            </button>
                            <button class="btn btn-outline-danger"
                                    data-bind="visible: scanning(), click: cancelScan">
                                <i class="bi bi-x-circle"></i> Cancel
                            </button>
                        </div>

                        <!-- Progress bar (visible while scanning) -->
                        <div data-bind="visible: scanning()" class="mt-3">
                            <div class="d-flex justify-content-between mb-1">
                                <small class="text-muted">
                                    <!-- ko if: scanProgress() && scanProgress().currentChannelName -->
                                    Processing: <strong data-bind="text: scanProgress().currentChannelName"></strong>
                                    <!-- /ko -->
                                    <!-- ko ifnot: scanProgress() && scanProgress().currentChannelName -->
                                    Starting scan&hellip;
                                    <!-- /ko -->
                                </small>
                                <small class="text-muted">
                                    <!-- ko if: scanProgress() -->
                                    <span data-bind="text: scanProgress().processedChannels"></span> / <span data-bind="text: scanProgress().totalChannels"></span> channels
                                    &nbsp;(<span data-bind="text: scanProgress().percentComplete"></span>%)
                                    <!-- /ko -->
                                </small>
                            </div>
                            <div class="progress" style="height: 18px;">
                                <div class="progress-bar progress-bar-striped progress-bar-animated bg-primary"
                                     role="progressbar"
                                     data-bind="style: { width: (scanProgress() ? scanProgress().percentComplete : 0) + '%' }"
                                     aria-valuemin="0" aria-valuemax="100">
                                </div>
                            </div>
                            <!-- ko if: scanProgress() -->
                            <small class="text-muted mt-1 d-block">
                                <span data-bind="text: scanProgress().newVideos"></span> new &middot;
                                <span data-bind="text: scanProgress().updatedVideos"></span> updated &middot;
                                <span data-bind="text: scanProgress().missingFiles"></span> missing so far
                            </small>
                            <!-- /ko -->
                        </div>

                        <!-- Result summary (visible after scan completes) -->
                        <div data-bind="visible: scanResult()" class="mt-3">
                            <div class="card bg-light">
                                <div class="card-body py-2">
                                    <small>
                                        <strong>Scan complete.</strong>
                                        <span data-bind="text: scanResult() && scanResult().newVideos"></span> new video(s),
                                        <span data-bind="text: scanResult() && scanResult().updatedVideos"></span> updated,
                                        <span data-bind="text: scanResult() && scanResult().flaggedForReview"></span> flagged for review,
                                        <span data-bind="text: scanResult() && scanResult().missingFiles"></span> missing from disk.
                                    </small>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-12 col-lg-6">
                <div class="card mb-4">
                    <div class="card-header">
                        <h5 class="mb-0"><i class="bi bi-arrow-repeat"></i> Channel Sync</h5>
                    </div>
                    <div class="card-body">
                        <p class="card-text text-muted">
                            Manually trigger a sync of all channels and playlists with their source platforms to discover new content.
                        </p>
                        <button class="btn btn-outline-primary me-2" data-bind="click: syncAllChannels, enable: !syncing()">
                            <i class="bi bi-broadcast"></i> Sync All Channels
                        </button>
                        <button class="btn btn-outline-secondary" data-bind="click: syncAllPlaylists, enable: !syncing()">
                            <i class="bi bi-collection-play"></i> Sync All Playlists
                        </button>
                    </div>
                </div>
                <div class="card mb-4">
                    <div class="card-header">
                        <h5 class="mb-0"><i class="bi bi-speedometer2"></i> Monitoring &amp; Diagnostics</h5>
                    </div>
                    <div class="card-body">
                        <p class="card-text text-muted">
                            Access scheduled tasks and application logs.
                        </p>
                        <div class="d-flex flex-wrap gap-2">
                            <a class="btn btn-outline-primary" href="/hangfire" target="_blank" rel="noopener noreferrer">
                                <i class="bi bi-clock-history"></i> Hangfire Dashboard
                            </a>
                            <a class="btn btn-outline-secondary" href="/sejil" target="_blank" rel="noopener noreferrer">
                                <i class="bi bi-journal-text"></i> Log Dashboard
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- ── Tags tab ─────────────────────────────────────────────────────────── -->
    <div class="tab-pane fade" id="tags" role="tabpanel">
        <div class="row">
            <div class="col-12 col-lg-6">
                <div class="card mb-4">
                    <div class="card-header">
                        <h5 class="mb-0"><i class="bi bi-tag-fill"></i> Global Tags</h5>
                    </div>
                    <div class="card-body">
                        <p class="text-muted small">
                            Global tags appear as suggestions to all users when they tag a video.
                            Adding a tag here will consolidate any existing per-user tags with the same name into this global one.
                        </p>

                        <!-- Add form -->
                        <div class="input-group mb-3">
                            <input type="text" class="form-control" placeholder="New tag name…"
                                   data-bind="value: newTagName, valueUpdate: 'input',
                                              event: { keydown: onNewTagKeyDown }" />
                            <button class="btn btn-primary"
                                    data-bind="click: addGlobalTag,
                                               enable: newTagName().trim().length > 0 && !addingTag()">
                                <span data-bind="visible: !addingTag()"><i class="bi bi-plus-lg"></i> Add</span>
                                <span data-bind="visible: addingTag()">
                                    <span class="spinner-border spinner-border-sm"></span>
                                </span>
                            </button>
                        </div>

                        <!-- Tag list -->
                        <div data-bind="visible: tagsLoading()" class="text-center py-3">
                            <div class="spinner-border spinner-border-sm" role="status"></div>
                        </div>

                        <div data-bind="visible: !tagsLoading() && globalTags().length === 0" class="text-muted small">
                            No global tags yet.
                        </div>

                        <div data-bind="visible: !tagsLoading() && globalTags().length > 0">
                            <ul class="list-group list-group-flush">
                                <!-- ko foreach: globalTags -->
                                <li class="list-group-item d-flex align-items-center justify-content-between px-0">
                                    <span>
                                        <i class="bi bi-tag me-1 text-muted"></i>
                                        <span data-bind="text: name"></span>
                                        <span class="badge bg-secondary ms-2" data-bind="text: usageCount" title="Videos tagged"></span>
                                    </span>
                                    <button class="btn btn-sm btn-outline-danger"
                                            data-bind="click: $parent.deleteGlobalTag"
                                            title="Delete global tag">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </li>
                                <!-- /ko -->
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- ── Failed Downloads tab ───────────────────────────────────────────── -->
    <div class="tab-pane fade" id="failed" role="tabpanel">
        <div class="alert alert-warning d-flex gap-2 mb-4">
            <i class="bi bi-info-circle-fill fs-5 flex-shrink-0 mt-1"></i>
            <div>
                <strong>These videos failed to download automatically.</strong>
                If you are able to obtain them by other means, rename the file using the <strong>Video ID</strong>
                (e.g. <code>5eVq-W1BGlY.mp4</code>) and place it in the appropriate channel folder under
                your configured download path. Then run a <strong>File System Scan</strong> from the Tools tab
                to import it.
            </div>
        </div>

        <div data-bind="visible: failedLoading()" class="text-center py-4">
            <div class="spinner-border" role="status">
                <span class="visually-hidden">Loading&hellip;</span>
            </div>
        </div>

        <div data-bind="visible: !failedLoading() && failedVideos().length === 0" class="alert alert-success">
            <i class="bi bi-check-circle-fill me-2"></i> No failed downloads. 
        </div>

        <div data-bind="visible: !failedLoading() && failedVideos().length > 0">
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead>
                        <tr>
                            <th style="width: 120px;"></th>
                            <th>Title</th>
                            <th>Platform</th>
                            <th>Channel</th>
                            <th>Channel ID</th>
                            <th>Video ID</th>
                        </tr>
                    </thead>
                    <tbody data-bind="foreach: failedVideos">
                        <tr>
                            <td>
                                <!-- ko if: thumbnailUrl -->
                                <img data-bind="attr: { src: thumbnailUrl, alt: title }"
                                     style="width: 120px; height: 68px; object-fit: cover; border-radius: 4px;" />
                                <!-- /ko -->
                                <!-- ko ifnot: thumbnailUrl -->
                                <div class="bg-secondary d-flex align-items-center justify-content-center rounded"
                                     style="width: 120px; height: 68px;">
                                    <i class="bi bi-play-circle text-white fs-4"></i>
                                </div>
                                <!-- /ko -->
                            </td>
                            <td>
                                <span class="fw-semibold" data-bind="text: title"></span>
                                <span class="badge bg-danger ms-2"><i class="bi bi-exclamation-triangle-fill"></i> Failed</span>
                                <!-- ko if: url -->
                                <a data-bind="attr: { href: url }" target="_blank" rel="noopener noreferrer" class="ms-2" title="Open original">
                                    <i class="bi bi-box-arrow-up-right"></i>
                                </a>
                                <!-- /ko -->
                            </td>
                            <td>
                                <span class="badge bg-secondary" data-bind="text: platform || '—'"></span>
                            </td>
                            <td data-bind="text: channelName"></td>
                            <td>
                                <code data-bind="text: channelId"></code>
                            </td>
                            <td>
                                <code data-bind="text: videoId"></code>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    @if (!AuthProvider.IsKeycloak)
    {
    <!-- ── Users tab ─────────────────────────────────────────────────────────── -->
    <div class="tab-pane fade" id="users" role="tabpanel">
        <div class="row mb-3">
            <div class="col d-flex justify-content-between align-items-center">
                <p class="text-muted mb-0">Manage user accounts. The current user row cannot be edited or deleted.</p>
                <button class="btn btn-primary" data-bind="click: showCreateUserModal">
                    <i class="bi bi-plus me-2"></i>Add User
                </button>
            </div>
        </div>
        <div class="row mb-3">
            <div class="col">
                <div class="position-relative">
                    <i class="bi bi-search position-absolute top-50 start-0 translate-middle-y ms-3 text-muted"></i>
                    <input type="text" class="form-control ps-5" placeholder="Search users..." data-bind="value: usersSearchTerm, valueUpdate: 'keyup'">
                </div>
            </div>
        </div>
        <div class="row">
            <div class="col">
                <div class="card">
                    <div class="card-body">
                        <!-- ko if: usersLoading() -->
                        <div class="text-center p-4">
                            <div class="spinner-border text-primary" role="status"><span class="visually-hidden">Loading...</span></div>
                            <p class="mt-2 text-muted">Loading users...</p>
                        </div>
                        <!-- /ko -->
                        <!-- ko if: !usersLoading() && filteredUsers().length === 0 -->
                        <div class="text-center p-4">
                            <i class="bi bi-people fs-1 text-muted"></i>
                            <p class="mt-2 text-muted">No users found</p>
                        </div>
                        <!-- /ko -->
                        <!-- ko if: !usersLoading() && filteredUsers().length > 0 -->
                        <div class="table-responsive">
                            <table class="table align-middle">
                                <thead>
                                    <tr>
                                        <th class="text-start">User</th>
                                        <th class="text-start">Role</th>
                                        <th class="text-start">Status</th>
                                        <th class="text-start">Actions</th>
                                    </tr>
                                </thead>
                                <tbody data-bind="foreach: filteredUsers">
                                    <tr>
                                        <td>
                                            <div class="d-flex align-items-center gap-2">
                                                <div class="rounded-circle bg-primary bg-opacity-10 d-flex align-items-center justify-content-center" style="width: 32px; height: 32px;">
                                                    <span class="text-primary fw-medium small" data-bind="text: initials"></span>
                                                </div>
                                                <div>
                                                    <span class="fw-medium" data-bind="text: userName"></span>
                                                    <!-- ko if: $root.isCurrentUser($data) -->
                                                    <span class="badge bg-info ms-1">You</span>
                                                    <!-- /ko -->
                                                    <p class="mb-0 small text-muted" data-bind="text: email"></p>
                                                </div>
                                            </div>
                                        </td>
                                        <td>
                                            <!-- ko if: roles.length > 0 -->
                                            <div class="d-flex flex-wrap gap-1" data-bind="foreach: roles">
                                                <span class="badge" data-bind="text: $data, css: $root.getRoleBadgeClass($data)"></span>
                                            </div>
                                            <!-- /ko -->
                                            <!-- ko if: roles.length === 0 -->
                                            <span class="badge bg-light text-dark">No Role</span>
                                            <!-- /ko -->
                                        </td>
                                        <td>
                                            <!-- ko if: isActive -->
                                            <span class="badge bg-success bg-opacity-10 text-success"><i class="bi bi-check-circle me-1"></i>Active</span>
                                            <!-- /ko -->
                                            <!-- ko if: !isActive -->
                                            <span class="badge bg-danger bg-opacity-10 text-danger"><i class="bi bi-x-circle me-1"></i>Disabled</span>
                                            <!-- /ko -->
                                        </td>
                                        <td>
                                            <!-- ko ifnot: $root.isCurrentUser($data) -->
                                            <div class="d-flex gap-2">
                                                <button class="btn btn-sm btn-outline-secondary" data-bind="click: $root.editUser">
                                                    <i class="bi bi-pencil-square me-1"></i>Edit
                                                </button>
                                                <button class="btn btn-sm btn-outline-secondary" data-bind="click: $root.toggleUserStatus">
                                                    <!-- ko if: isActive --><i class="bi bi-person-x me-1"></i>Disable<!-- /ko -->
                                                    <!-- ko if: !isActive --><i class="bi bi-person-check me-1"></i>Enable<!-- /ko -->
                                                </button>
                                                <button class="btn btn-sm btn-outline-danger" data-bind="click: $root.deleteUser">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </div>
                                            <!-- /ko -->
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                        <!-- /ko -->
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Create/Edit User Modal -->
    <div class="modal fade" id="userModal" tabindex="-1" aria-labelledby="userModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="userModalLabel" data-bind="text: userModalTitle">Add User</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <form data-bind="submit: saveUser">
                    <div class="modal-body">
                        <div class="mb-3">
                            <label for="userEmail" class="form-label">Email</label>
                            <input type="email" class="form-control" id="userEmail" data-bind="value: currentUser.email" required autocomplete="off">
                        </div>
                        <!-- ko if: isCreatingUser() -->
                        <div class="mb-3">
                            <label for="userPassword" class="form-label">Password</label>
                            <input type="password" class="form-control" id="userPassword" data-bind="value: currentUser.password" required autocomplete="new-password">
                            <div class="form-text">Password must be at least 6 characters long.</div>
                        </div>
                        <!-- /ko -->
                        <div class="mb-3">
                            <label for="userRole" class="form-label">Role</label>
                            <select class="form-select" id="userRole" data-bind="options: availableRoles, optionsText: 'name', optionsValue: 'name', value: currentUser.role, optionsCaption: 'Select a role...'"></select>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary" data-bind="disable: userSaving">
                            <!-- ko if: userSaving() -->
                            <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                            <!-- /ko -->
                            <span data-bind="text: userSaving() ? 'Saving...' : (isCreatingUser() ? 'Create User' : 'Update User')"></span>
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
    } @* end @if (!AuthProvider.IsKeycloak) *@

</div>

@section Scripts {
    <script type="module" src="~/js/admin-index.js"></script>
}
