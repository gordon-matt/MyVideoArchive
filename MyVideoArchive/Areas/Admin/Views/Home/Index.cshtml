@{
    ViewData["Title"] = "Admin";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="~/css/admin-index.css" asp-append-version="true" />
}

<div class="row mb-4">
    <div class="col-12">
        <h2><i class="bi bi-gear-fill"></i> Admin</h2>
        <p class="text-muted">Administrative tools and utilities</p>
    </div>
</div>

<div class="row">
    <div class="col-12 col-lg-6">
        <div class="card mb-4">
            <div class="card-header">
                <h5 class="mb-0"><i class="bi bi-folder-symlink"></i> File System</h5>
            </div>
            <div class="card-body">
                <p class="card-text text-muted">
                    Scan the configured downloads folder and reconcile video files with the database.
                    For non-Custom channels, checks convention paths (<code>OutputPath/{ChannelId}/{VideoId}</code>) for unlinked videos and detects files that no longer exist.
                    Custom channel files are enumerated from <code>OutputPath/_Custom/{ChannelId}/</code>.
                </p>
                <div id="scanStatus" class="alert d-none" role="alert"></div>

                <div class="d-flex gap-2 align-items-center flex-wrap">
                    <button id="btnScanFileSystem" class="btn btn-primary"
                            data-bind="click: scanFileSystem, enable: !scanning()">
                        <span data-bind="visible: !scanning()">
                            <i class="bi bi-search"></i> Scan File System
                        </span>
                        <span data-bind="visible: scanning()" class="d-none">
                            <i class="bi bi-search"></i> Scan File System
                        </span>
                    </button>
                    <button class="btn btn-outline-danger"
                            data-bind="visible: scanning(), click: cancelScan">
                        <i class="bi bi-x-circle"></i> Cancel
                    </button>
                </div>

                <!-- Progress bar (visible while scanning) -->
                <div data-bind="visible: scanning()" class="mt-3">
                    <div class="d-flex justify-content-between mb-1">
                        <small class="text-muted">
                            <!-- ko if: scanProgress() && scanProgress().currentChannelName -->
                            Processing: <strong data-bind="text: scanProgress().currentChannelName"></strong>
                            <!-- /ko -->
                            <!-- ko ifnot: scanProgress() && scanProgress().currentChannelName -->
                            Starting scan&hellip;
                            <!-- /ko -->
                        </small>
                        <small class="text-muted">
                            <!-- ko if: scanProgress() -->
                            <span data-bind="text: scanProgress().processedChannels"></span> / <span data-bind="text: scanProgress().totalChannels"></span> channels
                            &nbsp;(<span data-bind="text: scanProgress().percentComplete"></span>%)
                            <!-- /ko -->
                        </small>
                    </div>
                    <div class="progress" style="height: 18px;">
                        <div class="progress-bar progress-bar-striped progress-bar-animated bg-primary"
                             role="progressbar"
                             data-bind="style: { width: (scanProgress() ? scanProgress().percentComplete : 0) + '%' }"
                             aria-valuemin="0" aria-valuemax="100">
                        </div>
                    </div>
                    <!-- ko if: scanProgress() -->
                    <small class="text-muted mt-1 d-block">
                        <span data-bind="text: scanProgress().newVideos"></span> new &middot;
                        <span data-bind="text: scanProgress().updatedVideos"></span> updated &middot;
                        <span data-bind="text: scanProgress().missingFiles"></span> missing so far
                    </small>
                    <!-- /ko -->
                </div>

                <!-- Result summary (visible after scan completes) -->
                <div data-bind="visible: scanResult()" class="mt-3">
                    <div class="card bg-light">
                        <div class="card-body py-2">
                            <small>
                                <strong>Scan complete.</strong>
                                <span data-bind="text: scanResult() && scanResult().newVideos"></span> new video(s),
                                <span data-bind="text: scanResult() && scanResult().updatedVideos"></span> updated,
                                <span data-bind="text: scanResult() && scanResult().flaggedForReview"></span> flagged for review,
                                <span data-bind="text: scanResult() && scanResult().missingFiles"></span> missing from disk.
                            </small>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-12 col-lg-6">
        <div class="card mb-4">
            <div class="card-header">
                <h5 class="mb-0"><i class="bi bi-arrow-repeat"></i> Channel Sync</h5>
            </div>
            <div class="card-body">
                <p class="card-text text-muted">
                    Manually trigger a sync of all channels and playlists with their source platforms to discover new content.
                </p>
                <button class="btn btn-outline-primary me-2" data-bind="click: syncAllChannels, enable: !syncing()">
                    <i class="bi bi-broadcast"></i> Sync All Channels
                </button>
                <button class="btn btn-outline-secondary" data-bind="click: syncAllPlaylists, enable: !syncing()">
                    <i class="bi bi-collection-play"></i> Sync All Playlists
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script type="module" src="~/js/admin-index.js"></script>
}
