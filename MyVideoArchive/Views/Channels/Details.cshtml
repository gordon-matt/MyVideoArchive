@{
    ViewData["Title"] = "Channel Details";
    var channelId = ViewBag.ChannelId;
    var isAdminUser = User.IsInRole(Constants.Roles.Administrator);
}

@section Styles {
    <link rel="stylesheet" href="~/css/channel-details.css" />
}

<div class="row mb-4">
    <div class="col-12">
        <a href="/channels" class="btn btn-outline-secondary btn-sm mb-3">
            &larr; Back to Channels
        </a>
        <div data-bind="with: channel">
            <div class="channel-header-card">
                <div class="channel-details-banner-wrap position-relative">
                    <img class="channel-details-banner" data-bind="attr: { src: BannerUrl || 'https://placehold.co/1200x200?text=' + Name, alt: Name }" />
                    <button class="channel-img-edit-btn" title="Change banner image"
                            data-bind="click: $parent.editBanner">
                        <i class="bi bi-pencil-fill"></i>
                    </button>
                </div>
                <div class="channel-header-body d-flex align-items-start gap-3">
                    <div class="channel-avatar-wrap position-relative flex-shrink-0">
                        <img class="channel-avatar-img" data-bind="attr: { src: AvatarUrl || 'https://placehold.co/80x80?text=' + Name.charAt(0), alt: Name }" />
                        <button class="channel-img-edit-btn channel-avatar-edit-btn" title="Change avatar image"
                                data-bind="click: $parent.editAvatar">
                            <i class="bi bi-pencil-fill"></i>
                        </button>
                    </div>
                    <div>
                        <h2 data-bind="text: Name" class="mb-1"></h2>
                        <p data-bind="text: Description" class="channel-header-desc"></p>
                        <small>Subscribed: <span data-bind="text: $parent.formatDate(SubscribedAt)"></span></small>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<ul class="nav nav-tabs mb-4" id="channelTabs" role="tablist">
    <li class="nav-item" role="presentation">
        <button class="nav-link active" id="videos-tab" data-bs-toggle="tab" data-bs-target="#videos" type="button" role="tab">
            Videos
        </button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link" id="available-tab" data-bs-toggle="tab" data-bs-target="#available" type="button" role="tab">
            Available
        </button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link" id="playlists-tab" data-bs-toggle="tab" data-bs-target="#playlists" type="button" role="tab">
            Playlists
        </button>
    </li>
    @if (isAdminUser)
    {
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="subscribers-tab" data-bs-toggle="tab" data-bs-target="#subscribers" type="button" role="tab">
                <i class="bi bi-people"></i> Subscribers
                <span class="badge bg-primary rounded-pill ms-1"
                      data-bind="text: subscribersCount(), visible: subscribersCount() > 0"></span>
            </button>
        </li>
    }
</ul>

<div class="tab-content" id="channelTabsContent">

    <!-- ── Videos tab ─────────────────────────────────────────────────────── -->
    <div class="tab-pane fade show active" id="videos" role="tabpanel">

        <!-- Toolbar: search + playlist filter + view mode -->
        <div class="d-flex flex-wrap gap-2 align-items-center mb-3">
            <div class="input-group" style="max-width: 340px;">
                <input type="text" id="videosSearchInput" class="form-control" placeholder="Search videos…"
                       data-bind="value: videosSearchInput, valueUpdate: 'input'" />
                <button class="btn btn-primary" data-bind="click: searchVideos">
                    <i class="bi bi-search"></i>
                </button>
                <button class="btn btn-outline-secondary" data-bind="click: clearVideoSearch, visible: videosSearch()">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>

            <select class="form-select" style="max-width: 220px;" data-bind="value: videosPlaylistFilter">
                <option value="">All</option>
                <option value="-1">None (no playlist)</option>
                <!-- ko foreach: subscribedPlaylists -->
                <option data-bind="value: Id, text: Name"></option>
                <!-- /ko -->
            </select>

            <!-- Scan Files button -->
            <div class="d-flex gap-2 align-items-center">
                <button class="btn btn-outline-secondary" title="Scan files for this channel"
                        data-bind="click: scanFiles, enable: !scanningFiles()">
                    <span data-bind="visible: !scanningFiles()">
                        <i class="bi bi-folder-symlink"></i> Scan Files
                    </span>
                    <span data-bind="visible: scanningFiles()" class="d-none">
                        <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                        Scanning&hellip;
                    </span>
                </button>
                <button class="btn btn-outline-danger btn-sm" title="Cancel scan"
                        data-bind="visible: scanningFiles(), click: cancelScan">
                    <i class="bi bi-x-circle"></i>
                </button>
            </div>

            <div class="btn-group ms-auto">
                <button class="btn btn-outline-secondary" title="List view"
                        data-bind="click: function(){ setVideoViewMode('list'); }, css: { active: videoViewMode() === 'list' }">
                    <i class="bi bi-list-ul"></i>
                </button>
                <button class="btn btn-outline-secondary" title="Grid view"
                        data-bind="click: function(){ setVideoViewMode('grid'); }, css: { active: videoViewMode() === 'grid' }">
                    <i class="bi bi-grid-3x3-gap"></i>
                </button>
            </div>
        </div>

        <!-- Scan result alert -->
        <div data-bind="visible: scanMessage()" class="alert alert-info alert-dismissible mb-3">
            <span data-bind="text: scanMessage()"></span>
            <button type="button" class="btn-close" data-bind="click: function(){ scanMessage(null); }"></button>
        </div>

        <div data-bind="visible: loading" class="text-center">
            <div class="spinner-border" role="status">
                <span class="visually-hidden">Loading…</span>
            </div>
        </div>

        <div data-bind="visible: !loading() && videos().length === 0" class="alert alert-info">
            <p>No downloaded videos found. Check the "Available" tab to download videos.</p>
        </div>

        <!-- List view -->
        <div data-bind="visible: !loading() && videos().length > 0 && videoViewMode() === 'list', foreach: videos">
            <div class="video-item">
                <a data-bind="attr: { href: '/videos/' + id }" class="text-decoration-none d-flex align-items-center" style="flex: 1; min-width: 0;">
                    <img data-bind="attr: { src: thumbnailUrl || 'https://placehold.co/120x68?text=No+Thumbnail', alt: title }" class="video-thumbnail-small" />
                    <div style="flex: 1; min-width: 0;">
                        <h6 class="mb-1">
                            <span data-bind="text: title"></span>
                            <!-- ko if: watched() -->
                            <span class="badge bg-success ms-2"><i class="bi bi-eye"></i> Watched</span>
                            <!-- /ko -->
                        </h6>
                        <small class="text-muted">
                            Uploaded: <span data-bind="text: $parent.formatDate(uploadDate)"></span>
                            <span data-bind="if: downloadedAt"> | Downloaded: <span data-bind="text: $parent.formatDate(downloadedAt)"></span></span>
                        </small>
                    </div>
                    <div class="ms-3">
                        <i class="bi bi-play-circle fs-3 text-primary"></i>
                    </div>
                </a>
                <button class="btn btn-sm btn-outline-danger ms-3" data-bind="click: $parent.deleteVideoFile" title="Delete file">
                    <i class="bi bi-trash"></i>
                </button>
            </div>
        </div>

        <!-- Grid view -->
        <div data-bind="visible: !loading() && videos().length > 0 && videoViewMode() === 'grid'" class="row">
            <!-- ko foreach: videos -->
            <div class="col-xl-2 col-lg-3 col-md-4 col-sm-6 mb-3">
                <div class="video-grid-card card h-100">
                    <a data-bind="attr: { href: '/videos/' + id }" class="text-decoration-none">
                        <img data-bind="attr: { src: thumbnailUrl || 'https://placehold.co/320x180?text=No+Thumbnail', alt: title }"
                             class="card-img-top video-grid-thumbnail" />
                    </a>
                    <div class="card-body p-2">
                        <h6 class="video-grid-title mb-1" data-bind="text: title, attr: { title: title }"></h6>
                        <small class="text-muted d-block">
                            <span data-bind="text: $parent.formatDate(uploadDate)"></span>
                        </small>
                        <!-- ko if: watched() -->
                        <span class="badge bg-success mt-1"><i class="bi bi-eye"></i> Watched</span>
                        <!-- /ko -->
                    </div>
                    <div class="card-footer bg-transparent border-0 p-2 pt-0">
                        <button class="btn btn-sm btn-outline-danger w-100" data-bind="click: $parent.deleteVideoFile" title="Delete file">
                            <i class="bi bi-trash"></i> Delete
                        </button>
                    </div>
                </div>
            </div>
            <!-- /ko -->
        </div>

        @await Html.PartialAsync("_Pager", new MyVideoArchive.Models.PagerViewModel(
            AriaLabel: "Videos pagination",
            CurrentPageExpr: "videosCurrentPage",
            TotalPagesExpr: "videosTotalPages",
            TotalCountExpr: "videosTotalCount",
            PageNumbersExpr: "videosPageNumbers",
            PreviousPageFn: "videosPreviousPage",
            NextPageFn: "videosNextPage",
            GoToPageFn: "videosGoToPage",
            ItemLabel: "videos"))
    </div>

    <!-- ── Available tab ──────────────────────────────────────────────────── -->
    <div class="tab-pane fade" id="available" role="tabpanel">
        <div id="available-grid">
            <!-- Toolbar: search + show ignored + actions + view mode -->
            <div class="d-flex flex-wrap gap-2 align-items-center mb-3">
                <div class="input-group" style="max-width: 340px;">
                    <input type="text" id="availableVideosSearchInput" class="form-control" placeholder="Search available videos…"
                           data-bind="value: availableVideosSearchInput, valueUpdate: 'input'" />
                    <button class="btn btn-primary" data-bind="click: searchAvailableVideos">
                        <i class="bi bi-search"></i>
                    </button>
                    <button class="btn btn-outline-secondary" data-bind="click: clearAvailableSearch, visible: availableVideosSearch()">
                        <i class="bi bi-x-lg"></i>
                    </button>
                </div>
                <div class="form-check mb-0">
                    <input class="form-check-input" type="checkbox" id="showIgnoredCheck" data-bind="checked: showIgnored">
                    <label class="form-check-label" for="showIgnoredCheck">
                        Show Ignored Videos
                    </label>
                </div>
                <button class="btn btn-primary" data-bind="click: downloadSelected">
                    <i class="bi bi-download"></i> Download Selected
                </button>

                @if (isAdminUser)
                {
                    <button class="btn btn-success" data-bind="click: downloadAll">
                        <i class="bi bi-cloud-download"></i> Download All
                    </button>
                }

                <div class="btn-group ms-auto">
                    <button class="btn btn-outline-secondary" title="List view"
                            data-bind="click: function(){ setAvailableViewMode('list'); }, css: { active: availableViewMode() === 'list' }">
                        <i class="bi bi-list-ul"></i>
                    </button>
                    <button class="btn btn-outline-secondary" title="Grid view"
                            data-bind="click: function(){ setAvailableViewMode('grid'); }, css: { active: availableViewMode() === 'grid' }">
                        <i class="bi bi-grid-3x3-gap"></i>
                    </button>
                </div>
            </div>
            
            <div data-bind="visible: availableLoading" class="text-center my-4">
                <div class="spinner-border" role="status">
                    <span class="visually-hidden">Loading…</span>
                </div>
            </div>
            
            <div data-bind="visible: !availableLoading() && availableVideos().length === 0" class="alert alert-info">
                <p>No available videos found.</p>
            </div>
            
            <div data-bind="visible: !availableLoading() && availableVideos().length > 0">
                <div class="card mb-3">
                    <div class="card-header d-flex align-items-center">
                        <input type="checkbox" class="form-check-input me-2" data-bind="checked: selectAll">
                        <strong>Select All (Current Page)</strong>
                    </div>
                </div>
                
                <!-- Available list view -->
                <div data-bind="visible: availableViewMode() === 'list'">
                    <div data-bind="foreach: availableVideos">
                        <div class="available-video-item card mb-3">
                            <div class="card-body">
                                <div class="row">
                                    <div class="col-auto">
                                        <input type="checkbox" class="form-check-input video-checkbox" data-bind="checked: selected">
                                    </div>
                                    <div class="col-auto">
                                        <img data-bind="attr: { src: thumbnailUrl || 'https://placehold.co/160x90?text=No+Thumbnail', alt: title }" 
                                             style="width: 160px; height: 90px; object-fit: cover; border-radius: 4px;">
                                    </div>
                                    <div class="col">
                                        <h6>
                                            <span data-bind="text: title"></span>
                                            <a data-bind="attr: { href: url }" target="_blank" class="ms-2 text-muted" title="View original" onclick="event.stopPropagation();">
                                                <i class="bi bi-box-arrow-up-right small"></i>
                                            </a>
                                        </h6>
                                        <p class="text-muted small mb-1" data-bind="text: description" style="max-height: 60px; overflow: hidden;"></p>
                                        <small class="text-muted">
                                            Uploaded: <span data-bind="text: $parent.formatDate(uploadDate)"></span>
                                            <span data-bind="if: duration"> | Duration: <span data-bind="text: $parent.formatDuration(duration)"></span></span>
                                        </small>
                                        <div data-bind="if: isDownloaded" class="mt-1">
                                            <span class="badge bg-success">Downloaded</span>
                                        </div>
                                        <div data-bind="if: downloadFailed" class="mt-1">
                                            <span class="badge bg-danger"><i class="bi bi-exclamation-triangle-fill"></i> Failed</span>
                                        </div>
                                        <div data-bind="if: isIgnored" class="mt-1">
                                            <span class="badge bg-secondary">Ignored</span>
                                        </div>
                                    </div>
                                    <div class="col-auto d-flex align-items-center">
                                        <button class="btn btn-sm btn-outline-danger" data-bind="click: $parent.ignoreVideo">
                                            <span data-bind="text: isIgnored ? 'Unignore' : 'Ignore'"></span>
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                
                <!-- Available grid view -->
                <div data-bind="visible: availableViewMode() === 'grid'" class="row">
                    <!-- ko foreach: availableVideos -->
                    <div class="col-xl-2 col-lg-3 col-md-4 col-sm-6 mb-3">
                        <div class="video-grid-card card h-100">
                            <div class="position-relative">
                                <input type="checkbox" class="form-check-input position-absolute top-0 start-0 m-2" style="z-index: 1;"
                                       data-bind="checked: selected, click: function(data, event) { event.stopPropagation(); return true; }">
                                <a data-bind="attr: { href: url }" target="_blank" class="text-decoration-none" onclick="event.stopPropagation();">
                                    <img data-bind="attr: { src: thumbnailUrl || 'https://placehold.co/320x180?text=No+Thumbnail', alt: title }"
                                         class="card-img-top video-grid-thumbnail" />
                                </a>
                            </div>
                            <div class="card-body p-2">
                                <h6 class="video-grid-title mb-1" data-bind="text: title, attr: { title: title }"></h6>
                                <small class="text-muted d-block">
                                    <span data-bind="text: $parent.formatDate(uploadDate)"></span>
                                    <span data-bind="if: duration"> &middot; <span data-bind="text: $parent.formatDuration(duration)"></span></span>
                                </small>
                                <div class="d-flex flex-wrap gap-1 mt-1">
                                    <span data-bind="if: isDownloaded" class="badge bg-success">Downloaded</span>
                                    <span data-bind="if: downloadFailed" class="badge bg-danger"><i class="bi bi-exclamation-triangle-fill"></i> Failed</span>
                                    <span data-bind="if: isIgnored" class="badge bg-secondary">Ignored</span>
                                </div>
                            </div>
                            <div class="card-footer bg-transparent border-0 p-2 pt-0 d-flex gap-1">
                                <a data-bind="attr: { href: url }" target="_blank" class="btn btn-sm btn-outline-secondary flex-fill" onclick="event.stopPropagation();">
                                    <i class="bi bi-box-arrow-up-right"></i>
                                </a>
                                <button class="btn btn-sm btn-outline-danger" data-bind="click: $parent.ignoreVideo" title="Ignore">
                                    <span data-bind="text: isIgnored ? 'Unignore' : 'Ignore'"></span>
                                </button>
                            </div>
                        </div>
                    </div>
                    <!-- /ko -->
                </div>
                
                @await Html.PartialAsync("_Pager", new MyVideoArchive.Models.PagerViewModel(
                    AriaLabel: "Available videos pagination",
                    CurrentPageExpr: "currentPage",
                    TotalPagesExpr: "totalPages",
                    TotalCountExpr: "totalCount",
                    PageNumbersExpr: "pageNumbers",
                    PreviousPageFn: "previousPage",
                    NextPageFn: "nextPage",
                    GoToPageFn: "goToPage",
                    ItemLabel: "videos"))
            </div>
        </div>
    </div>

    @if (isAdminUser)
    {
        <!-- ── Subscribers tab (admin only) ──────────────────────────────────────── -->
        <div class="tab-pane fade" id="subscribers" role="tabpanel">
            <div data-bind="visible: subscribersLoading" class="text-center my-4">
                <div class="spinner-border" role="status">
                    <span class="visually-hidden">Loading&hellip;</span>
                </div>
            </div>

            <div data-bind="visible: !subscribersLoading() && subscribers().length === 0" class="alert alert-info">
                <i class="bi bi-info-circle me-2"></i>
                No users are subscribed to this channel.
            </div>

            <div data-bind="visible: !subscribersLoading() && subscribers().length > 0">
                <div class="d-flex align-items-center gap-2 mb-3">
                    <i class="bi bi-people-fill text-primary fs-5"></i>
                    <h5 class="mb-0">
                        <span data-bind="text: subscribersCount()"></span>
                        subscriber<span data-bind="visible: subscribersCount() !== 1">s</span>
                    </h5>
                </div>
                <div class="table-responsive">
                    <table class="table table-hover align-middle">
                        <thead class="table-light">
                            <tr>
                                <th><i class="bi bi-person me-1"></i>Username</th>
                                <th><i class="bi bi-envelope me-1"></i>Email</th>
                                <th><i class="bi bi-calendar-check me-1"></i>Subscribed</th>
                            </tr>
                        </thead>
                        <tbody data-bind="foreach: subscribers">
                            <tr>
                                <td>
                                    <span class="fw-semibold" data-bind="text: username"></span>
                                </td>
                                <td class="text-muted" data-bind="text: email"></td>
                                <td class="text-muted">
                                    <span data-bind="text: $parent.formatDate(subscribedAt)"></span>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }

    <!-- ── Playlists tab ──────────────────────────────────────────────────── -->
    <div class="tab-pane fade" id="playlists" role="tabpanel">
        <div id="playlists-grid">
            <div class="mb-3">
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" id="showIgnoredPlaylistsCheck" data-bind="checked: showIgnoredPlaylists">
                    <label class="form-check-label" for="showIgnoredPlaylistsCheck">
                        Show Ignored Playlists
                    </label>
                </div>
            </div>
            
            <div class="mb-3">
                <button class="btn btn-info me-2" data-bind="click: refreshPlaylists, enable: !refreshingPlaylists() && !subscribingPlaylists()">
                    <span data-bind="visible: !refreshingPlaylists()"><i class="bi bi-arrow-clockwise"></i> Refresh from <span data-bind="text: channel() ? channel().Platform : ''"></span></span>
                    <span data-bind="visible: refreshingPlaylists()">
                        <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                        Refreshing…
                    </span>
                </button>
                <button class="btn btn-primary me-2" data-bind="click: subscribeSelectedPlaylists, enable: !subscribingPlaylists()">
                    <i class="bi bi-plus-circle"></i> Subscribe Selected
                </button>

                @if (isAdminUser)
                {
                    <button class="btn btn-success" data-bind="click: subscribeAllPlaylists, enable: !subscribingPlaylists()">
                        <i class="bi bi-check-circle"></i> Subscribe All
                    </button>
                }
            </div>

            <!-- ko if: subscribingPlaylists -->
            <div class="alert alert-info d-flex align-items-center gap-2 mb-3">
                <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                <span>Subscribing. Please wait…</span>
            </div>
            <!-- /ko -->
            
            <div data-bind="visible: playlistsLoading" class="text-center my-4">
                <div class="spinner-border" role="status">
                    <span class="visually-hidden">Loading…</span>
                </div>
            </div>
            
            <div data-bind="visible: !playlistsLoading() && playlists().length === 0" class="alert alert-info">
                <p>No playlists found for this channel.</p>
            </div>
            
            <div data-bind="visible: !playlistsLoading() && playlists().length > 0">
                <div class="card mb-3">
                    <div class="card-header d-flex align-items-center">
                        <input type="checkbox" class="form-check-input me-2" data-bind="checked: selectAllPlaylists">
                        <strong>Select All</strong>
                    </div>
                </div>
                
                <div class="row">
                    <!-- ko foreach: playlists -->
                    <div class="col-xl-2 col-lg-3 col-md-4 col-sm-6 mb-3">
                        <div class="playlist-card card h-100">
                            <div class="position-relative">
                                <input type="checkbox" class="playlist-checkbox-overlay form-check-input" data-bind="checked: selected, click: function(data, event) { event.stopPropagation(); return true; }">
                                <a data-bind="attr: { href: isSubscribed ? '/playlists/' + id : 'javascript:void(0)' }, css: { 'disabled-link': !isSubscribed }">
                                    <!-- ko if: thumbnailUrl -->
                                    <img data-bind="attr: { src: thumbnailUrl, alt: name }"
                                         class="card-img-top playlist-thumbnail">
                                    <!-- /ko -->
                                    <!-- ko ifnot: thumbnailUrl -->
                                    <div class="card-img-top playlist-thumbnail d-flex align-items-center justify-content-center bg-secondary">
                                        <i class="bi bi-collection-play text-white fs-2"></i>
                                    </div>
                                    <!-- /ko -->
                                </a>
                            </div>
                            <div class="card-body p-2">
                                <h6 class="card-title playlist-card-title" data-bind="text: name, attr: { title: name }"></h6>
                                <small class="text-muted d-block mb-2">
                                    <span data-bind="if: videoCount"><i class="bi bi-collection-play"></i> <span data-bind="text: videoCount"></span> videos</span>
                                </small>
                                <div class="d-flex flex-wrap gap-1">
                                    <span data-bind="if: isSubscribed" class="badge bg-success">Subscribed</span>
                                    <span data-bind="if: isIgnored" class="badge bg-secondary">Ignored</span>
                                </div>
                            </div>
                            <div class="card-footer bg-transparent border-0 p-2 pt-0 d-flex flex-column gap-1">
                                <a data-bind="attr: { href: url }, visible: url" target="_blank" class="btn btn-sm btn-outline-secondary w-100">
                                    <i class="bi bi-box-arrow-up-right"></i>
                                    View on <span data-bind="text: platform"></span>
                                </a>
                                <button class="btn btn-sm btn-outline-danger w-100" data-bind="click: $parent.ignorePlaylist">
                                    <span data-bind="text: isIgnored ? 'Unignore' : 'Ignore'"></span>
                                </button>
                            </div>
                        </div>
                    </div>
                    <!-- /ko -->
                </div>

                @await Html.PartialAsync("_Pager", new MyVideoArchive.Models.PagerViewModel(
                    AriaLabel: "Playlists pagination",
                    CurrentPageExpr: "playlistsCurrentPage",
                    TotalPagesExpr: "playlistsTotalPages",
                    TotalCountExpr: "playlistsTotalCount",
                    PageNumbersExpr: "playlistsPageNumbers",
                    PreviousPageFn: "playlistsPreviousPage",
                    NextPageFn: "playlistsNextPage",
                    GoToPageFn: "playlistsGoToPage",
                    ItemLabel: "playlists"))
            </div>
        </div>
    </div>
</div>

<!-- ── Thumbnail Picker Modal ──────────────────────────────────────────────── -->
<div class="modal fade" id="thumbnailPickerModal" tabindex="-1" aria-labelledby="thumbnailPickerModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="thumbnailPickerModalLabel">
                    <span data-bind="visible: thumbnailPickerMode() === 'banner'">Change Banner Image</span>
                    <span data-bind="visible: thumbnailPickerMode() === 'avatar'">Change Avatar Image</span>
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">

                <!-- Tabs -->
                <ul class="nav nav-tabs mb-3" role="tablist">
                    <li class="nav-item">
                        <button class="nav-link active" id="thumbPicker-platform-tab" data-bs-toggle="tab" data-bs-target="#thumbPicker-platform" type="button">
                            <i class="bi bi-images"></i> Platform Images
                        </button>
                    </li>
                    <li class="nav-item">
                        <button class="nav-link" id="thumbPicker-upload-tab" data-bs-toggle="tab" data-bs-target="#thumbPicker-upload" type="button">
                            <i class="bi bi-upload"></i> Upload Custom
                        </button>
                    </li>
                </ul>

                <div class="tab-content">
                    <!-- Platform Images Tab -->
                    <div class="tab-pane fade show active" id="thumbPicker-platform" role="tabpanel">
                        <div data-bind="visible: thumbnailPickerLoading()" class="text-center py-4">
                            <div class="spinner-border" role="status"></div>
                            <p class="mt-2 text-muted">Fetching images from platform…</p>
                        </div>
                        <div data-bind="visible: !thumbnailPickerLoading() && thumbnailPickerItems().length === 0" class="alert alert-info">
                            No platform images available for this channel. Use "Upload Custom" to add your own.
                        </div>
                        <div data-bind="visible: !thumbnailPickerLoading() && thumbnailPickerItems().length > 0" class="thumbnail-picker-grid">
                            <!-- ko foreach: thumbnailPickerItems -->
                            <div class="thumbnail-picker-item" data-bind="css: { 'thumb-selected': $parent.isSelectedForCurrentMode($data) }, click: $parent.selectThumbnail">
                                <img data-bind="attr: { src: url, alt: '' }" class="thumbnail-picker-img" loading="lazy" />
                                <div class="thumbnail-picker-meta">
                                    <!-- ko if: width && height -->
                                    <span class="badge bg-dark" data-bind="text: width + ' × ' + height"></span>
                                    <!-- /ko -->
                                    <!-- ko ifnot: width && height -->
                                    <span class="badge bg-secondary">Unknown size</span>
                                    <!-- /ko -->
                                </div>
                                <div class="thumbnail-picker-selected-badge" data-bind="visible: $parent.isSelectedForCurrentMode($data)">
                                    <i class="bi bi-check-circle-fill text-success"></i> Selected
                                </div>
                            </div>
                            <!-- /ko -->
                        </div>
                    </div>

                    <!-- Upload Custom Tab -->
                    <div class="tab-pane fade" id="thumbPicker-upload" role="tabpanel">
                        <div class="thumbnail-upload-zone"
                             data-bind="event: { dragover: onImageDragOver, drop: onImageDrop }"
                             onclick="document.getElementById('thumbnailPickerFileInput').click()">
                            <i class="bi bi-cloud-upload fs-1 text-muted"></i>
                            <p class="mt-2 mb-0">Drag &amp; drop an image here, or <strong>click to browse</strong></p>
                            <small class="text-muted">JPG, PNG or WebP &middot; Max 10 MB</small>
                            <input type="file" id="thumbnailPickerFileInput" accept="image/jpeg,image/png,image/webp" class="d-none"
                                   data-bind="event: { change: onImageFileSelected }" />
                        </div>
                        <div data-bind="visible: thumbnailPickerUploadPreview()" class="mt-3 text-center">
                            <img data-bind="attr: { src: thumbnailPickerUploadPreview() }" class="thumbnail-upload-preview" />
                            <div class="mt-2">
                                <button class="btn btn-sm btn-outline-danger" data-bind="click: clearUploadPreview">
                                    <i class="bi bi-x"></i> Remove
                                </button>
                            </div>
                        </div>
                    </div>
                </div>

            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" data-bind="click: confirmThumbnailPicker, enable: canConfirmThumbnailPicker()">
                    Apply
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script type="text/javascript">
        const channelId = @channelId;
        const isAdmin = @(isAdminUser ? "true" : "false");
    </script>
    <script type="module" src="~/js/channel-details.js"></script>
}
