@{
    ViewData["Title"] = "Custom Channel";
    var channelId = ViewBag.ChannelId;
}

@section Styles {
    <link rel="stylesheet" href="~/css/channel-details.css" />
}

<div class="row mb-4">
    <div class="col-12">
        <a href="/channels" class="btn btn-outline-secondary btn-sm mb-3">
            &larr; Back to Channels
        </a>

        <div data-bind="with: channel">
            <div class="channel-header-card">
                <div class="channel-details-banner-wrap">
                    <img class="channel-details-banner" data-bind="attr: { src: ThumbnailUrl || 'https://placehold.co/1200x200?text=' + Name, alt: Name }" />
                </div>
                <div class="channel-header-body">
                    <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
                        <div class="d-flex align-items-center gap-2">
                            <h2 data-bind="text: Name" class="mb-0"></h2>
                            <span class="badge bg-secondary">Custom</span>
                        </div>
                        <button class="btn btn-outline-light btn-sm" data-bind="click: $parent.openEditChannel">
                            <i class="bi bi-pencil"></i> Edit
                        </button>
                    </div>
                    <p data-bind="text: Description" class="channel-header-desc"></p>
                    <small>Subscribed: <span data-bind="text: $parent.formatDate(SubscribedAt)"></span></small>
                </div>
            </div>
        </div>
    </div>
</div>

<ul class="nav nav-tabs mb-4" id="channelTabs" role="tablist">
    <li class="nav-item" role="presentation">
        <button class="nav-link active" id="videos-tab" data-bs-toggle="tab" data-bs-target="#videos" type="button" role="tab">
            Videos
        </button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link" id="playlists-tab" data-bs-toggle="tab" data-bs-target="#playlists" type="button" role="tab">
            Playlists
        </button>
    </li>
</ul>

<div class="tab-content" id="channelTabsContent">

    <!-- ── Videos tab ─────────────────────────────────────────────────────── -->
    <div class="tab-pane fade show active" id="videos" role="tabpanel">

        <!-- Toolbar: search + view mode -->
        <div class="d-flex flex-wrap gap-2 align-items-center mb-3">
            <div class="input-group" style="max-width: 340px;">
                <input type="text" id="videosSearchInput" class="form-control" placeholder="Search videos…"
                       data-bind="value: videosSearchInput, valueUpdate: 'input'" />
                <button class="btn btn-primary" data-bind="click: searchVideos">
                    <i class="bi bi-search"></i>
                </button>
                <button class="btn btn-outline-secondary" data-bind="click: clearVideoSearch, visible: videosSearch()">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>

            <div class="btn-group ms-auto">
                <button class="btn btn-outline-secondary" title="List view"
                        data-bind="click: function(){ setVideoViewMode('list'); }, css: { active: videoViewMode() === 'list' }">
                    <i class="bi bi-list-ul"></i>
                </button>
                <button class="btn btn-outline-secondary" title="Grid view"
                        data-bind="click: function(){ setVideoViewMode('grid'); }, css: { active: videoViewMode() === 'grid' }">
                    <i class="bi bi-grid-3x3-gap"></i>
                </button>
            </div>
        </div>

        <div data-bind="visible: loading" class="text-center">
            <div class="spinner-border" role="status"><span class="visually-hidden">Loading…</span></div>
        </div>

        <div data-bind="visible: !loading() && videos().length === 0" class="alert alert-info">
            <p>No videos yet. Copy video files into the channel's download folder and use <a href="/admin">Admin &rsaquo; Scan File System</a> to import them, or add them manually.</p>
        </div>

        <!-- List view -->
        <div data-bind="visible: !loading() && videos().length > 0 && videoViewMode() === 'list', foreach: videos">
            <a data-bind="attr: { href: '/videos/' + Id }" class="text-decoration-none">
                <div class="video-item">
                    <img data-bind="attr: { src: ThumbnailUrl || 'https://placehold.co/120x68?text=No+Thumbnail', alt: Title }"
                         class="video-thumbnail-small" />
                    <div style="flex: 1;">
                        <h6 data-bind="text: Title"></h6>
                        <small class="text-muted">
                            <span data-bind="if: UploadDate">Uploaded: <span data-bind="text: $parent.formatDate(UploadDate)"></span></span>
                        </small>
                        <span data-bind="if: NeedsMetadataReview" class="badge bg-danger ms-2">Needs Review</span>
                    </div>
                    <div class="ms-auto">
                        <i class="bi bi-play-circle fs-3 text-primary"></i>
                    </div>
                </div>
            </a>
        </div>

        <!-- Grid view -->
        <div data-bind="visible: !loading() && videos().length > 0 && videoViewMode() === 'grid'" class="row">
            <!-- ko foreach: videos -->
            <div class="col-xl-2 col-lg-3 col-md-4 col-sm-6 mb-3">
                <div class="video-grid-card card h-100">
                    <a data-bind="attr: { href: '/videos/' + Id }" class="text-decoration-none">
                        <img data-bind="attr: { src: ThumbnailUrl || 'https://placehold.co/320x180?text=No+Thumbnail', alt: Title }"
                             class="card-img-top video-grid-thumbnail" />
                    </a>
                    <div class="card-body p-2">
                        <h6 class="video-grid-title mb-1" data-bind="text: Title, attr: { title: Title }"></h6>
                        <small class="text-muted d-block">
                            <span data-bind="if: UploadDate"><span data-bind="text: $parent.formatDate(UploadDate)"></span></span>
                        </small>
                        <span data-bind="if: NeedsMetadataReview" class="badge bg-danger mt-1">Needs Review</span>
                    </div>
                </div>
            </div>
            <!-- /ko -->
        </div>

        <!-- Videos pagination -->
        <nav aria-label="Videos pagination" data-bind="visible: !loading() && videosTotalPages() > 1" class="mt-3">
            <ul class="pagination justify-content-center">
                <li class="page-item" data-bind="css: { disabled: videosCurrentPage() === 1 }">
                    <a class="page-link" href="#" data-bind="click: videosPreviousPage">Previous</a>
                </li>
                <!-- ko foreach: videosPageNumbers -->
                <li class="page-item" data-bind="css: { active: $data === $parent.videosCurrentPage() }">
                    <a class="page-link" href="#" data-bind="text: $data, click: function() { $parent.videosGoToPage($data); }"></a>
                </li>
                <!-- /ko -->
                <li class="page-item" data-bind="css: { disabled: videosCurrentPage() === videosTotalPages() }">
                    <a class="page-link" href="#" data-bind="click: videosNextPage">Next</a>
                </li>
            </ul>
            <p class="text-center text-muted small">
                Page <span data-bind="text: videosCurrentPage"></span> of <span data-bind="text: videosTotalPages"></span>
                (<span data-bind="text: videosTotalCount"></span> total)
            </p>
        </nav>
    </div>

    <!-- ── Playlists tab ──────────────────────────────────────────────────── -->
    <div class="tab-pane fade" id="playlists" role="tabpanel">
        <div class="mb-3">
            <button class="btn btn-primary" data-bind="click: openCreatePlaylist">
                <i class="bi bi-plus-circle"></i> Create Playlist
            </button>
        </div>
        <div data-bind="visible: playlistsLoading" class="text-center">
            <div class="spinner-border" role="status"><span class="visually-hidden">Loading…</span></div>
        </div>
        <div data-bind="visible: !playlistsLoading() && playlists().length === 0" class="alert alert-info">
            <p>No playlists yet. Click "Create Playlist" to get started.</p>
        </div>
        <div data-bind="visible: !playlistsLoading() && playlists().length > 0" class="row">
            <!-- ko foreach: playlists -->
            <div class="col-xl-2 col-lg-3 col-md-4 col-sm-6 mb-3">
                <div class="card h-100">
                    <a data-bind="attr: { href: '/playlists/' + Id }">
                        <!-- ko if: ThumbnailUrl -->
                        <img data-bind="attr: { src: ThumbnailUrl + '?t=' + $parent.thumbnailCacheBust(), alt: Name }"
                             class="card-img-top"
                             style="height: 120px; object-fit: cover;" />
                        <!-- /ko -->
                        <!-- ko ifnot: ThumbnailUrl -->
                        <div class="card-img-top d-flex align-items-center justify-content-center bg-secondary"
                             style="height: 120px;">
                            <i class="bi bi-collection-play text-white fs-2"></i>
                        </div>
                        <!-- /ko -->
                    </a>
                    <div class="card-body p-2">
                        <h6 class="card-title mb-1" data-bind="text: Name"></h6>
                    </div>
                    <div class="card-footer p-1 d-flex gap-1">
                        <button class="btn btn-sm btn-outline-secondary flex-fill"
                                data-bind="click: $parent.openThumbnailModal"
                                onclick="event.stopPropagation();">
                            <i class="bi bi-image"></i> Thumbnail
                        </button>
                        <button class="btn btn-sm btn-outline-danger"
                                data-bind="click: $parent.deletePlaylist"
                                onclick="event.stopPropagation();"
                                title="Delete playlist">
                            <i class="bi bi-trash"></i>
                        </button>
                    </div>
                </div>
            </div>
            <!-- /ko -->
        </div>

        <!-- Playlists pagination -->
        <nav aria-label="Playlists pagination" data-bind="visible: !playlistsLoading() && playlistsTotalPages() > 1" class="mt-3">
            <ul class="pagination justify-content-center">
                <li class="page-item" data-bind="css: { disabled: playlistsCurrentPage() === 1 }">
                    <a class="page-link" href="#" data-bind="click: playlistsPreviousPage">Previous</a>
                </li>
                <!-- ko foreach: playlistsPageNumbers -->
                <li class="page-item" data-bind="css: { active: $data === $parent.playlistsCurrentPage() }">
                    <a class="page-link" href="#" data-bind="text: $data, click: function() { $parent.playlistsGoToPage($data); }"></a>
                </li>
                <!-- /ko -->
                <li class="page-item" data-bind="css: { disabled: playlistsCurrentPage() === playlistsTotalPages() }">
                    <a class="page-link" href="#" data-bind="click: playlistsNextPage">Next</a>
                </li>
            </ul>
            <p class="text-center text-muted small">
                Page <span data-bind="text: playlistsCurrentPage"></span> of <span data-bind="text: playlistsTotalPages"></span>
                (<span data-bind="text: playlistsTotalCount"></span> total playlists)
            </p>
        </nav>
    </div>
</div>

<!-- Edit Channel Modal -->
<div class="modal fade" id="editChannelModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Edit Channel</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label class="form-label">Name <span class="text-danger">*</span></label>
                    <input type="text" class="form-control" data-bind="value: editName" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Description</label>
                    <textarea class="form-control" rows="3" data-bind="value: editDescription"></textarea>
                </div>
                <div class="mb-3">
                    <label class="form-label">Thumbnail URL</label>
                    <input type="text" class="form-control" data-bind="value: editThumbnailUrl"
                           placeholder="https://..." />
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" data-bind="click: saveChannel, enable: editName().length > 0">Save</button>
            </div>
        </div>
    </div>
</div>

<!-- Playlist Thumbnail Modal -->
<div class="modal fade" id="playlistThumbnailModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    Edit Thumbnail &mdash; <span data-bind="text: thumbnailTargetPlaylist() && thumbnailTargetPlaylist().Name"></span>
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div id="playlistDropZone"
                     class="border rounded p-4 text-center position-relative"
                     style="border-style: dashed !important; cursor: pointer; min-height: 160px;"
                     data-bind="event: { dragover: onThumbnailDragOver, drop: onThumbnailDrop, click: triggerThumbnailInput }">
                    <div data-bind="visible: !thumbnailPreviewUrl()">
                        <i class="bi bi-cloud-arrow-up fs-1 text-muted"></i>
                        <p class="text-muted mt-2 mb-0">Drag &amp; drop an image here, or click to browse</p>
                        <small class="text-muted">JPG, PNG or WebP &mdash; max 10 MB</small>
                    </div>
                    <img data-bind="visible: thumbnailPreviewUrl(), attr: { src: thumbnailPreviewUrl }"
                         style="max-width: 100%; max-height: 240px; object-fit: contain;" />
                </div>
                <input type="file" id="playlistThumbnailInput" accept="image/*" style="display:none;"
                       data-bind="event: { change: onThumbnailFileSelected }" />
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary"
                        data-bind="click: uploadPlaylistThumbnail, enable: thumbnailFile() && !uploadingThumbnail()">
                    <span data-bind="visible: !uploadingThumbnail()"><i class="bi bi-save"></i> Save</span>
                    <span data-bind="visible: uploadingThumbnail()">
                        <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                        Saving…
                    </span>
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Create Playlist Modal -->
<div class="modal fade" id="createPlaylistModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Create Playlist</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label class="form-label">Name <span class="text-danger">*</span></label>
                    <input type="text" class="form-control" data-bind="value: newPlaylistName" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Description</label>
                    <textarea class="form-control" rows="3" data-bind="value: newPlaylistDescription"></textarea>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" data-bind="click: createPlaylist, enable: newPlaylistName().length > 0">Create</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script type="text/javascript">
        const channelId = @channelId;
    </script>
    <script type="module" src="~/js/channel-details-custom.js"></script>
}
