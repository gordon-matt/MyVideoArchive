@using MyVideoArchive
@{
    ViewData["Title"] = "Channels";
    bool isAdmin = User.IsInRole(Constants.Roles.Administrator);
}

@section Styles {
    <link rel="stylesheet" href="~/css/channel-index.css" asp-append-version="true" />
}

<div class="container">
    <div class="row mb-3">
        <div class="col-8">
            <h2>@(isAdmin ? "All Channels" : "My Channels")</h2>
            <p class="text-muted">@(isAdmin ? "All channels in the archive" : "Channels you are subscribed to")</p>
        </div>
        <div class="col-4 text-end">
            <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addChannelModal">
                <i class="bi bi-plus-circle"></i> Add Channel
            </button>
        </div>
    </div>

    <div class="row mb-4 align-items-center">
        <div class="col-md-3">
            <select class="form-select" data-bind="value: platformFilter">
                <option value="">All Platforms</option>
                <option value="YouTube">YouTube</option>
                <option value="BitChute">BitChute</option>
                <option value="Custom">Custom</option>
            </select>
        </div>
        <div class="col-md-9 d-flex justify-content-end align-items-center gap-3 flex-wrap">
            @if (isAdmin)
            {
                <!-- Include Unsubbed toggle (admin only) -->
                <div class="form-check form-switch mb-0">
                    <input class="form-check-input" type="checkbox" id="includeUnsubbedSwitch"
                           data-bind="checked: includeUnsubbed" />
                    <label class="form-check-label" for="includeUnsubbedSwitch">
                        <i class="bi bi-eye me-1"></i> Include Unsubbed
                    </label>
                </div>
            }
            <!-- Enable Categories toggle -->
            <div class="form-check form-switch mb-0">
                <input class="form-check-input" type="checkbox" id="enableCategoriesSwitch"
                       data-bind="checked: enableChannelCategories" />
                <label class="form-check-label" for="enableCategoriesSwitch">
                    <i class="bi bi-folder2-open me-1"></i> Enable Categories
                </label>
            </div>
            <!-- Banner/Avatar view toggle — hidden when categories are enabled -->
            <div class="btn-group" data-bind="visible: !enableChannelCategories()">
                <button class="btn btn-outline-secondary" title="Banner view"
                        data-bind="click: function(){ setChannelViewMode('banner'); }, css: { active: channelViewMode() === 'banner' }">
                    <i class="bi bi-layout-text-sidebar-reverse"></i> Banner
                </button>
                <button class="btn btn-outline-secondary" title="Avatar grid view"
                        data-bind="click: function(){ setChannelViewMode('avatar'); }, css: { active: channelViewMode() === 'avatar' }">
                    <i class="bi bi-grid-3x3-gap"></i> Avatar
                </button>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-12">
            <div data-bind="visible: loading" class="text-center py-5">
                <div class="spinner-border" role="status">
                    <span class="visually-hidden">Loading...</span>
                </div>
            </div>

            <div data-bind="visible: !loading() && channels().length === 0" class="alert alert-info">
                <p>@(isAdmin ? "No channels in the archive yet." : "No channels yet. Click \"Add Channel\" to subscribe to your first channel.")</p>
            </div>

            <!-- ════════════════════════════════════════════════════════════════
                 CATEGORIZED VIEW  (Enable Categories ON)
                 ════════════════════════════════════════════════════════════════ -->
            <div data-bind="visible: !loading() && channels().length > 0 && enableChannelCategories()">

                <!-- ko foreach: categorizedGroups() -->
                <div class="category-section" data-bind="visible: channels.length > 0">
                    <div class="category-section-header">
                        <!-- ko if: category.thumbnailUrl -->
                        <img data-bind="attr: { src: category.thumbnailUrl, alt: category.name }" class="category-thumb" />
                        <!-- /ko -->
                        <!-- ko ifnot: category.thumbnailUrl -->
                        <div class="category-icon-fallback"><i class="bi bi-folder2-open"></i></div>
                        <!-- /ko -->
                        <span class="category-section-title" data-bind="text: category.name"></span>
                        <span class="category-section-count text-muted"
                              data-bind="text: '(' + channels.length + ' channel' + (channels.length !== 1 ? 's' : '') + ')'"></span>
                        <div class="category-section-actions ms-auto">
                            <button class="btn btn-outline-danger btn-sm" title="Delete category"
                                    data-bind="click: $root.deleteCategory.bind($root, category)"
                                    onclick="event.stopPropagation()">
                                <i class="bi bi-trash"></i>
                            </button>
                        </div>
                    </div>
                    <div class="row">
                        <!-- ko foreach: channels -->
                        <div class="col-xl-2 col-lg-3 col-md-4 col-sm-6 mb-4">
                            <div class="channel-avatar-card" data-bind="click: $root.viewChannel, css: { 'channel-avatar-card--unsubbed': subscriberCount === 0 }">
                                <div class="channel-avatar-card-img-wrap">
                                    <img data-bind="attr: { src: avatarUrl || bannerUrl || 'https://placehold.co/160x160?text=' + name.charAt(0), alt: name }"
                                         class="channel-avatar-card-img" />
                                    <button class="btn btn-sm channel-avatar-card-edit-btn" title="Edit category"
                                            data-bind="click: $root.openEditCategoryModal.bind($root, $data)"
                                            onclick="event.stopPropagation()">
                                        <i class="bi bi-pencil"></i>
                                    </button>
                                </div>
                                <div class="channel-avatar-card-body">
                                    <div class="channel-avatar-card-name" data-bind="text: name, attr: { title: name }"></div>
                                    <div class="channel-avatar-card-meta">
                                        <!-- ko if: platform === 'Custom' --><span class="badge bg-secondary me-1">Custom</span><!-- /ko -->
                                        <!-- ko if: subscriberCount === 0 -->
                                        <span class="badge bg-secondary"><i class="bi bi-person-x me-1"></i>No subscribers</span>
                                        <!-- /ko -->
                                        <!-- ko ifnot: subscriberCount === 0 -->
                                        <span data-bind="text: $root.formatDate(subscribedAt)" class="text-muted small"></span>
                                        <!-- /ko -->
                                    </div>
                                </div>
                                <div class="channel-avatar-card-actions d-flex gap-1" onclick="event.stopPropagation()">
                                    @if (isAdmin)
                                    {
                                        <button class="btn btn-outline-secondary btn-sm" title="Assign to users"
                                                data-bind="click: $root.openAssignUsersModal">
                                            <i class="bi bi-person-plus-fill"></i>
                                        </button>
                                    }
                                    <button class="btn btn-danger btn-sm flex-fill"
                                            data-bind="click: $root.deleteChannel, text: $root.isAdmin ? 'Delete' : 'Unsubscribe'"></button>
                                </div>
                            </div>
                        </div>
                        <!-- /ko -->
                    </div>
                </div>
                <!-- /ko -->

                <!-- Uncategorized channels -->
                <!-- ko if: uncategorizedChannels().length > 0 -->
                <div class="category-section">
                    <div class="uncategorized-section-header">
                        <i class="bi bi-question-circle"></i>
                        Uncategorized
                        <span class="ms-1 fw-normal text-muted small"
                              data-bind="text: '(' + uncategorizedChannels().length + ' channel' + (uncategorizedChannels().length !== 1 ? 's' : '') + ')'"></span>
                    </div>
                    <div class="row">
                        <!-- ko foreach: uncategorizedChannels() -->
                        <div class="col-xl-2 col-lg-3 col-md-4 col-sm-6 mb-4">
                            <div class="channel-avatar-card" data-bind="click: $root.viewChannel, css: { 'channel-avatar-card--unsubbed': subscriberCount === 0 }">
                                <div class="channel-avatar-card-img-wrap">
                                    <img data-bind="attr: { src: avatarUrl || bannerUrl || 'https://placehold.co/160x160?text=' + name.charAt(0), alt: name }"
                                         class="channel-avatar-card-img" />
                                    <button class="btn btn-sm channel-avatar-card-edit-btn" title="Assign to category"
                                            data-bind="click: $root.openEditCategoryModal.bind($root, $data)"
                                            onclick="event.stopPropagation()">
                                        <i class="bi bi-pencil"></i>
                                    </button>
                                </div>
                                <div class="channel-avatar-card-body">
                                    <div class="channel-avatar-card-name" data-bind="text: name, attr: { title: name }"></div>
                                    <div class="channel-avatar-card-meta">
                                        <!-- ko if: platform === 'Custom' --><span class="badge bg-secondary me-1">Custom</span><!-- /ko -->
                                        <!-- ko if: subscriberCount === 0 -->
                                        <span class="badge bg-secondary"><i class="bi bi-person-x me-1"></i>No subscribers</span>
                                        <!-- /ko -->
                                        <!-- ko ifnot: subscriberCount === 0 -->
                                        <span data-bind="text: $root.formatDate(subscribedAt)" class="text-muted small"></span>
                                        <!-- /ko -->
                                    </div>
                                </div>
                                <div class="channel-avatar-card-actions d-flex gap-1" onclick="event.stopPropagation()">
                                    @if (isAdmin)
                                    {
                                        <button class="btn btn-outline-secondary btn-sm" title="Assign to users"
                                                data-bind="click: $root.openAssignUsersModal">
                                            <i class="bi bi-person-plus-fill"></i>
                                        </button>
                                    }
                                    <button class="btn btn-danger btn-sm flex-fill"
                                            data-bind="click: $root.deleteChannel, text: $root.isAdmin ? 'Delete' : 'Unsubscribe'"></button>
                                </div>
                            </div>
                        </div>
                        <!-- /ko -->
                    </div>
                </div>
                <!-- /ko -->

            </div>

            <!-- ════════════════════════════════════════════════════════════════
                 STANDARD VIEW  (Enable Categories OFF)
                 ════════════════════════════════════════════════════════════════ -->
            <div data-bind="visible: !loading() && channels().length > 0 && !enableChannelCategories()">

                <!-- ── Banner view ──────────────────────────────────────────── -->
                <div data-bind="visible: channelViewMode() === 'banner'">
                    <!-- ko foreach: channels -->
                    <div class="channel-card" data-bind="css: { 'channel-card--unsubbed': subscriberCount === 0 }">
                        <div class="channel-banner-wrap" data-bind="click: $parent.viewChannel">
                            <img data-bind="attr: { src: bannerUrl || avatarUrl || 'https://placehold.co/1200x200?text=' + name, alt: name }" class="channel-banner" />
                        </div>
                        <div class="channel-card-body">
                            <div class="channel-info" data-bind="click: $parent.viewChannel">
                                <div class="channel-name" data-bind="text: name"></div>
                                <div class="channel-url" data-bind="text: url"></div>
                                <div class="channel-meta">
                                    <span data-bind="if: platform === 'Custom'" class="badge bg-secondary me-1">Custom</span>
                                    <!-- ko if: subscriberCount === 0 -->
                                    <span class="badge bg-secondary"><i class="bi bi-person-x me-1"></i>No subscribers</span>
                                    <!-- /ko -->
                                    <!-- ko ifnot: subscriberCount === 0 -->
                                    Subscribed: <span data-bind="text: $parent.formatDate(subscribedAt)"></span>
                                    <!-- /ko -->
                                </div>
                            </div>
                            <div class="channel-actions d-flex gap-2">
                                <!-- ko if: $parent.isAdmin -->
                                <button class="btn btn-outline-secondary btn-sm" title="Assign to users"
                                        data-bind="click: $parent.openAssignUsersModal" onclick="event.stopPropagation();">
                                    <i class="bi bi-person-plus-fill"></i>
                                </button>
                                <!-- /ko -->
                                <button class="btn btn-danger btn-sm" data-bind="click: $parent.deleteChannel, text: $parent.isAdmin ? 'Delete' : 'Unsubscribe'" onclick="event.stopPropagation();"></button>
                            </div>
                        </div>
                    </div>
                    <!-- /ko -->
                </div>

                <!-- ── Avatar grid view ─────────────────────────────────────── -->
                <div data-bind="visible: channelViewMode() === 'avatar'" class="row">
                    <!-- ko foreach: channels -->
                    <div class="col-xl-2 col-lg-3 col-md-4 col-sm-6 mb-4">
                        <div class="channel-avatar-card" data-bind="click: $parent.viewChannel, css: { 'channel-avatar-card--unsubbed': subscriberCount === 0 }">
                            <div class="channel-avatar-card-img-wrap">
                                <img data-bind="attr: { src: avatarUrl || bannerUrl || 'https://placehold.co/160x160?text=' + name.charAt(0), alt: name }"
                                     class="channel-avatar-card-img" />
                            </div>
                            <div class="channel-avatar-card-body">
                                <div class="channel-avatar-card-name" data-bind="text: name, attr: { title: name }"></div>
                                <div class="channel-avatar-card-meta">
                                    <span data-bind="if: platform === 'Custom'" class="badge bg-secondary me-1">Custom</span>
                                    <!-- ko if: subscriberCount === 0 -->
                                    <span class="badge bg-secondary"><i class="bi bi-person-x me-1"></i>No subscribers</span>
                                    <!-- /ko -->
                                    <!-- ko ifnot: subscriberCount === 0 -->
                                    <span data-bind="text: $parent.formatDate(subscribedAt)" class="text-muted small"></span>
                                    <!-- /ko -->
                                </div>
                            </div>
                            <div class="channel-avatar-card-actions d-flex gap-1" onclick="event.stopPropagation()">
                                <!-- ko if: $parent.isAdmin -->
                                <button class="btn btn-outline-secondary btn-sm" title="Assign to users"
                                        data-bind="click: $parent.openAssignUsersModal">
                                    <i class="bi bi-person-plus-fill"></i>
                                </button>
                                <!-- /ko -->
                                <button class="btn btn-danger btn-sm flex-fill" data-bind="click: $parent.deleteChannel, text: $parent.isAdmin ? 'Delete' : 'Unsubscribe'"></button>
                            </div>
                        </div>
                    </div>
                    <!-- /ko -->
                </div>

            </div>
        </div>
    </div>

    <!-- ── Add Channel Modal ─────────────────────────────────────────────────── -->
    <div class="modal fade" id="addChannelModal" tabindex="-1" aria-labelledby="addChannelModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="addChannelModalLabel">Add Channel</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <form id="addChannelForm">
                        <div class="mb-3">
                            <label for="platformSelect" class="form-label">Platform</label>
                            <select class="form-select" id="platformSelect" data-bind="value: selectedPlatform">
                                <option value="YouTube">YouTube</option>
                                <option value="BitChute">BitChute</option>
                                <option value="Custom">Custom (archive videos from any source)</option>
                            </select>
                        </div>

                        <div data-bind="visible: isUrlBasedPlatform()">
                            <div class="mb-3">
                                <label for="channelUrl" class="form-label">Channel URL</label>
                                <input type="text" class="form-control" id="channelUrl" data-bind="value: newChannelUrl"
                                       placeholder="https://www.youtube.com/channel/... or https://www.bitchute.com/channel/..." />
                                <div class="form-text">Enter the channel URL. Metadata will be fetched automatically.</div>
                            </div>
                        </div>

                        <div data-bind="visible: selectedPlatform() === 'Custom'">
                            <div class="mb-3">
                                <label for="customChannelName" class="form-label">Channel Name <span class="text-danger">*</span></label>
                                <input type="text" class="form-control" id="customChannelName" data-bind="value: customChannelName"
                                       placeholder="My Custom Channel" />
                            </div>
                            <div class="mb-3">
                                <label for="customChannelDescription" class="form-label">Description</label>
                                <textarea class="form-control" id="customChannelDescription" rows="3"
                                          data-bind="value: customChannelDescription"
                                          placeholder="Optional description"></textarea>
                            </div>
                            <div class="form-text text-muted">
                                <i class="bi bi-info-circle"></i>
                                Custom channels let you organise videos from platforms not supported by the automatic downloader.
                                You can add metadata and upload files from the channel details page.
                            </div>
                        </div>
                    </form>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal" data-bind="enable: !isAddingChannel()">Cancel</button>
                    <button type="button" class="btn btn-primary"
                            data-bind="click: addChannel, enable: canSubmit() && !isAddingChannel()">
                        <span data-bind="visible: !isAddingChannel()">
                            <i class="bi bi-plus-circle me-1"></i>Add Channel
                        </span>
                        <span data-bind="visible: isAddingChannel()">
                            <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                            Adding&hellip;
                        </span>
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- ── Edit Channel Category Modal ──────────────────────────────────────── -->
    <div class="modal fade" id="editChannelCategoryModal" tabindex="-1" aria-labelledby="editChannelCategoryModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="editChannelCategoryModalLabel">
                        <i class="bi bi-folder2-open me-2"></i>Assign Category
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <p class="text-muted mb-3">
                        Channel: <strong data-bind="text: editCategoryChannel() ? editCategoryChannel().name : ''"></strong>
                    </p>

                    <div class="mb-3">
                        <label class="form-label">Category</label>
                        <select class="form-select" data-bind="value: editCategoryDropdownValue">
                            <option value="">— No category —</option>
                            <!-- ko foreach: categories() -->
                            <option data-bind="value: String(id), text: name"></option>
                            <!-- /ko -->
                            <option value="__create_new__">+ Create new category…</option>
                        </select>
                    </div>

                    <div data-bind="visible: editCategoryCreatingNew()" class="mb-3">
                        <label class="form-label">New category name</label>
                        <input type="text" class="form-control" placeholder="e.g. Tech, Gaming, News…"
                               data-bind="value: editCategoryNewName, valueUpdate: 'input'" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal"
                            data-bind="enable: !editCategorySaving()">Cancel</button>
                    <button type="button" class="btn btn-primary"
                            data-bind="click: confirmEditCategory, enable: !editCategorySaving()">
                        <span data-bind="visible: !editCategorySaving()">
                            <i class="bi bi-check-circle me-1"></i>Save
                        </span>
                        <span data-bind="visible: editCategorySaving()">
                            <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                            Saving&hellip;
                        </span>
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- ── Admin Delete Channel Modal ────────────────────────────────────────── -->
    <div class="modal fade" id="adminDeleteChannelModal" tabindex="-1" aria-labelledby="adminDeleteChannelModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="adminDeleteChannelModalLabel">Delete Channel</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <p>Are you sure you want to unsubscribe all users from <strong data-bind="text: channelToDelete() ? channelToDelete().name : ''"></strong>?</p>
                    <p class="fw-semibold">Actions:</p>
                    <div class="mb-2">
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" id="adminDeleteUnsubscribeAll" checked disabled>
                            <label class="form-check-label" for="adminDeleteUnsubscribeAll">Unsubscribe all users</label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" id="adminDeleteMetadata" data-bind="checked: adminDeleteMetadata">
                            <label class="form-check-label" for="adminDeleteMetadata">Delete all metadata</label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" id="adminDeleteFiles" data-bind="checked: adminDeleteFiles">
                            <label class="form-check-label" for="adminDeleteFiles">Delete video files</label>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-danger" data-bind="click: confirmAdminDelete">Confirm Delete</button>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ── Thumbnail Picker Modal ──────────────────────────────────────────────── -->
<div class="modal fade" id="thumbnailPickerModal" tabindex="-1" aria-labelledby="thumbnailPickerModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="thumbnailPickerModalLabel">Select Channel Images</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p class="text-muted">Choose which images to use as the <strong>banner</strong> and <strong>avatar</strong> for this channel. You can also upload your own.</p>

                <ul class="nav nav-tabs mb-3" role="tablist">
                    <li class="nav-item">
                        <button class="nav-link active" id="thumbPicker-platform-tab" data-bs-toggle="tab" data-bs-target="#thumbPicker-platform" type="button">
                            <i class="bi bi-images"></i> Platform Images
                        </button>
                    </li>
                    <li class="nav-item">
                        <button class="nav-link" id="thumbPicker-upload-tab" data-bs-toggle="tab" data-bs-target="#thumbPicker-upload" type="button">
                            <i class="bi bi-upload"></i> Upload Custom
                        </button>
                    </li>
                </ul>

                <div class="tab-content">
                    <div class="tab-pane fade show active" id="thumbPicker-platform" role="tabpanel">
                        <div data-bind="visible: thumbnailPickerLoading()" class="text-center py-4">
                            <div class="spinner-border" role="status"></div>
                            <p class="mt-2 text-muted">Fetching images from platform…</p>
                        </div>
                        <div data-bind="visible: !thumbnailPickerLoading() && thumbnailPickerItems().length === 0" class="alert alert-info">
                            No platform images found. Use "Upload Custom" to add your own.
                        </div>
                        <div data-bind="visible: !thumbnailPickerLoading() && thumbnailPickerItems().length > 0">
                            <p class="text-muted small mb-2">Choose <strong>Banner</strong> or <strong>Avatar</strong>, then click a thumbnail below to assign it.</p>
                            <div class="d-flex gap-3 mb-3 flex-wrap">
                                <div class="thumbnail-selection-preview thumbnail-assign-target"
                                     data-bind="css: { 'thumbnail-assign-target-active': thumbnailPickerAssignTo() === 'banner' }, click: setThumbnailAssignToBanner">
                                    <label class="form-label fw-semibold mb-1 cursor-pointer">
                                        <i class="bi bi-layout-text-sidebar-reverse me-1"></i> Banner
                                        <span data-bind="visible: thumbnailPickerAssignTo() === 'banner'" class="badge bg-primary ms-1">Select thumbnail for this</span>
                                    </label>
                                    <img data-bind="attr: { src: selectedBannerUrl() || 'https://placehold.co/240x80?text=None' }"
                                         class="thumbnail-selection-preview-img banner-preview-img" />
                                    <button class="btn btn-sm btn-outline-danger mt-1 w-100" data-bind="click: function(d,e){ clearBannerSelection(); e.stopPropagation(); }, visible: selectedBannerUrl()">
                                        <i class="bi bi-x"></i> Clear
                                    </button>
                                </div>
                                <div class="thumbnail-selection-preview thumbnail-assign-target"
                                     data-bind="css: { 'thumbnail-assign-target-active': thumbnailPickerAssignTo() === 'avatar' }, click: setThumbnailAssignToAvatar">
                                    <label class="form-label fw-semibold mb-1 cursor-pointer">
                                        <i class="bi bi-person-circle me-1"></i> Avatar
                                        <span data-bind="visible: thumbnailPickerAssignTo() === 'avatar'" class="badge bg-success ms-1">Select thumbnail for this</span>
                                    </label>
                                    <img data-bind="attr: { src: selectedAvatarUrl() || 'https://placehold.co/80x80?text=None' }"
                                         class="thumbnail-selection-preview-img avatar-preview-img" />
                                    <button class="btn btn-sm btn-outline-danger mt-1 w-100" data-bind="click: function(d,e){ clearAvatarSelection(); e.stopPropagation(); }, visible: selectedAvatarUrl()">
                                        <i class="bi bi-x"></i> Clear
                                    </button>
                                </div>
                            </div>
                            <div class="thumbnail-picker-grid">
                                <!-- ko foreach: thumbnailPickerItems -->
                                <div class="thumbnail-picker-item"
                                     data-bind="css: { 'thumb-banner': $parent.selectedBannerUrl() === url, 'thumb-avatar': $parent.selectedAvatarUrl() === url }, click: $parent.selectThumbnailForIndex">
                                    <img data-bind="attr: { src: url, alt: '' }" class="thumbnail-picker-img" loading="lazy" />
                                    <div class="thumbnail-picker-meta">
                                        <!-- ko if: width && height -->
                                        <span class="badge bg-dark" data-bind="text: width + ' × ' + height"></span>
                                        <!-- /ko -->
                                        <!-- ko ifnot: width && height -->
                                        <span class="badge bg-secondary">Unknown size</span>
                                        <!-- /ko -->
                                    </div>
                                    <div class="thumbnail-picker-selected-badge" data-bind="visible: $parent.selectedBannerUrl() === url">
                                        <span class="badge bg-primary">Banner</span>
                                    </div>
                                    <div class="thumbnail-picker-selected-badge thumbnail-avatar-badge" data-bind="visible: $parent.selectedAvatarUrl() === url">
                                        <span class="badge bg-success">Avatar</span>
                                    </div>
                                </div>
                                <!-- /ko -->
                            </div>
                        </div>
                    </div>

                    <div class="tab-pane fade" id="thumbPicker-upload" role="tabpanel">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label fw-semibold">Banner Image</label>
                                <div class="thumbnail-upload-zone"
                                     data-bind="event: { dragover: onBannerDragOver, drop: onBannerDrop }"
                                     onclick="document.getElementById('bannerFileInput').click()">
                                    <i class="bi bi-panorama fs-2 text-muted"></i>
                                    <p class="mt-1 mb-0 small">Click or drag &amp; drop</p>
                                    <input type="file" id="bannerFileInput" accept="image/jpeg,image/png,image/webp" class="d-none"
                                           data-bind="event: { change: onBannerFileSelected }" />
                                </div>
                                <div data-bind="visible: bannerUploadPreview()" class="mt-2 text-center">
                                    <img data-bind="attr: { src: bannerUploadPreview() }" class="thumbnail-upload-preview w-100" />
                                    <button class="btn btn-sm btn-outline-danger mt-1" data-bind="click: clearBannerUpload">
                                        <i class="bi bi-x"></i> Remove
                                    </button>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-semibold">Avatar Image</label>
                                <div class="thumbnail-upload-zone"
                                     data-bind="event: { dragover: onAvatarDragOver, drop: onAvatarDrop }"
                                     onclick="document.getElementById('avatarFileInput').click()">
                                    <i class="bi bi-person-circle fs-2 text-muted"></i>
                                    <p class="mt-1 mb-0 small">Click or drag &amp; drop</p>
                                    <input type="file" id="avatarFileInput" accept="image/jpeg,image/png,image/webp" class="d-none"
                                           data-bind="event: { change: onAvatarFileSelected }" />
                                </div>
                                <div data-bind="visible: avatarUploadPreview()" class="mt-2 text-center">
                                    <img data-bind="attr: { src: avatarUploadPreview() }" class="thumbnail-upload-preview avatar-upload-preview" />
                                    <button class="btn btn-sm btn-outline-danger mt-1" data-bind="click: clearAvatarUpload">
                                        <i class="bi bi-x"></i> Remove
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

            </div>
            <div class="modal-footer d-flex justify-content-between">
                <button type="button" class="btn btn-outline-secondary" data-bind="click: skipThumbnailPicker">
                    Skip
                </button>
                <div class="d-flex gap-2">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-primary" data-bind="click: confirmThumbnailPicker">
                        Apply &amp; Continue
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ── Assign Users to Channel Modal (admin only) ──────────────────────────── -->
<div class="modal fade" id="assignUsersModal" tabindex="-1" aria-labelledby="assignUsersModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="assignUsersModalLabel">
                    <i class="bi bi-person-plus-fill me-2"></i>
                    Assign Channel to Users
                    <small class="text-muted fw-normal ms-2" data-bind="text: assignUsersChannel() ? '— ' + assignUsersChannel().name : ''"></small>
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body" style="max-height: 60vh; overflow-y: auto;">
                <div data-bind="visible: assignUsersLoading" class="text-center py-4">
                    <div class="spinner-border" role="status">
                        <span class="visually-hidden">Loading…</span>
                    </div>
                </div>

                <div data-bind="visible: !assignUsersLoading() && assignUsersAll().length === 0" class="alert alert-info">
                    No users found.
                </div>

                <div data-bind="visible: !assignUsersLoading() && assignUsersAll().length > 0">
                    <p class="text-muted small mb-3">
                        Check users who should have access to this channel. Unchecking a user removes their subscription.
                    </p>
                    <div class="list-group" data-bind="foreach: assignUsersAll">
                        <label class="list-group-item list-group-item-action d-flex align-items-center gap-3 cursor-pointer">
                            <input type="checkbox" class="form-check-input flex-shrink-0" data-bind="checked: isSubscribed" />
                            <div class="flex-grow-1">
                                <div class="fw-semibold" data-bind="text: username"></div>
                                <small class="text-muted" data-bind="text: email"></small>
                            </div>
                            <!-- ko if: isSubscribed -->
                            <span class="badge bg-success">Subscribed</span>
                            <!-- /ko -->
                        </label>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary"
                        data-bind="click: confirmAssignUsers, enable: !assignUsersSaving() && !assignUsersLoading()">
                    <span data-bind="visible: !assignUsersSaving()">
                        <i class="bi bi-check-circle me-1"></i> Save
                    </span>
                    <span data-bind="visible: assignUsersSaving()" class="d-none">
                        <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                        Saving&hellip;
                    </span>
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        window.isAdminUser = @(isAdmin ? "true" : "false");
    </script>
    <script type="module" src="~/js/channel-index.js" asp-append-version="true"></script>
}
