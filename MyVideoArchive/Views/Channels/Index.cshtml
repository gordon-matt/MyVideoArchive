@{
    ViewData["Title"] = "Channels";
}

@section Styles {
    <link rel="stylesheet" href="~/css/channel-index.css" />
}

<div class="row mb-4">
    <div class="col-8">
        <h2>My Channels</h2>
        <p class="text-muted">Channels you are subscribed to</p>
    </div>
    <div class="col-4 text-end">
        <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addChannelModal">
            <i class="bi bi-plus-circle"></i> Add Channel
        </button>
    </div>
</div>

<div class="row">
    <div class="col-12">
        <div id="channels-grid"></div>
    </div>
</div>

<!-- Add Channel Modal -->
<div class="modal fade" id="addChannelModal" tabindex="-1" aria-labelledby="addChannelModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="addChannelModalLabel">Add Channel</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="addChannelForm">
                    <div class="mb-3">
                        <label for="channelUrl" class="form-label">Channel URL</label>
                        <input type="text" class="form-control" id="channelUrl" data-bind="value: newChannelUrl" placeholder="https://www.youtube.com/channel/..." required>
                        <div class="form-text">Enter a YouTube channel URL</div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" data-bind="click: addChannel, enable: newChannelUrl().length > 0">Add Channel</button>
            </div>
        </div>
    </div>
</div>

<div data-bind="visible: loading" class="text-center">
    <div class="spinner-border" role="status">
        <span class="visually-hidden">Loading...</span>
    </div>
</div>

<div data-bind="visible: !loading() && channels().length === 0" class="alert alert-info">
    <p>No channels yet. Click "Add Channel" to subscribe to your first channel.</p>
</div>

<div data-bind="visible: !loading() && channels().length > 0">
    <!-- ko foreach: channels -->
    <div class="channel-card">
        <div class="d-flex align-items-center">
            <img data-bind="attr: { src: ThumbnailUrl || 'https://via.placeholder.com/88?text=No+Image', alt: Name }" class="channel-thumbnail" />
            <div class="channel-info" data-bind="click: $parent.viewChannel">
                <div class="channel-name" data-bind="text: Name"></div>
                <div class="channel-url" data-bind="text: Url"></div>
                <div class="channel-meta">
                    Subscribed: <span data-bind="text: $parent.formatDate(SubscribedAt)"></span>
                </div>
            </div>
            <div class="channel-actions">
                <button class="btn btn-danger btn-sm" data-bind="click: $parent.deleteChannel" onclick="event.stopPropagation();">
                    Unsubscribe
                </button>
            </div>
        </div>
    </div>
    <!-- /ko -->
</div>

@section Scripts {
    <script type="module" src="~/js/channel-index.js"></script>
}