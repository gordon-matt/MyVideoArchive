@{
    ViewData["Title"] = "Downloads";
}

@section Styles {
    <link rel="stylesheet" href="~/css/downloads.css" />
}

<div class="row mb-4">
    <div class="col-8">
        <h2>Video Queue</h2>
        <p class="text-muted">Manage video downloads from your subscribed channels</p>
    </div>
    <div class="col-4 text-end">
        <button type="button" class="btn btn-success" data-bind="click: checkForNewVideos, enable: !checking()">
            <span data-bind="visible: !checking()"><i class="bi bi-arrow-clockwise"></i> Check for Updates</span>
            <span data-bind="visible: checking()">
                <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                Checking...
            </span>
        </button>
    </div>
</div>

<div class="row mb-3">
    <div class="col-md-3 mb-2 mb-md-0">
        <select class="form-select" data-bind="value: selectedChannelId">
            <option value="">All Channels</option>
            <!-- ko foreach: channels -->
            <option data-bind="value: Id, text: Name"></option>
            <!-- /ko -->
        </select>
    </div>
    <div class="col-md-9">
        <div class="btn-group" role="group">
            <button type="button" class="btn btn-outline-primary" data-bind="css: { active: statusFilter() === 'all' }, click: function() { statusFilter('all'); loadVideos(); }">
                All
            </button>
            <button type="button" class="btn btn-outline-primary" data-bind="css: { active: statusFilter() === 'available' }, click: function() { statusFilter('available'); loadVideos(); }">
                Available
            </button>
            <button type="button" class="btn btn-outline-primary" data-bind="css: { active: statusFilter() === 'queued' }, click: function() { statusFilter('queued'); loadVideos(); }">
                Queued
            </button>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-12">
        <div data-bind="visible: loading" class="text-center">
            <div class="spinner-border" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
        </div>

        <div data-bind="visible: !loading() && videos().length === 0" class="alert alert-info">
            <p>No videos found matching your filters.</p>
        </div>

        <div data-bind="visible: !loading() && videos().length > 0">
            <!-- ko foreach: videos -->
            <div class="video-download-item" data-bind="css: { queued: isQueued }">
                <img data-bind="attr: { src: thumbnailUrl || 'https://placehold.co/160x90?text=No+Thumbnail', alt: title }" class="video-thumbnail-list" />
                <div class="video-details">
                    <div class="video-title-large">
                        <span data-bind="text: title"></span>
                        <a data-bind="attr: { href: url }" target="_blank" class="ms-2 text-muted" title="View original">
                            <i class="bi bi-box-arrow-up-right small"></i>
                        </a>
                    </div>
                    <div class="video-channel-name" data-bind="text: channelName"></div>
                    <div class="video-meta-info">
                        Uploaded: <span data-bind="text: $parent.formatDate(uploadDate)"></span>
                        <span data-bind="if: duration"> | Duration: <span data-bind="text: $parent.formatDuration(duration)"></span></span>
                    </div>
                    <div class="mt-2">
                        <span data-bind="if: isQueued" class="badge bg-warning text-dark">
                            <i class="bi bi-hourglass-split"></i> Queued for Download
                        </span>
                        <span data-bind="if: !isQueued" class="badge bg-info">
                            <i class="bi bi-cloud-arrow-down"></i> Available
                        </span>
                    </div>
                </div>
                <div class="download-actions">
                    <button class="btn btn-primary btn-sm" data-bind="click: $parent.downloadVideo, visible: !isQueued, enable: !isQueued">
                        <i class="bi bi-download"></i> Download
                    </button>
                    <span data-bind="visible: isQueued" class="text-warning">
                        <i class="bi bi-hourglass-split"></i> Queued
                    </span>
                </div>
            </div>
            <!-- /ko -->
            
            <!-- Pagination -->
            <nav aria-label="Videos pagination" data-bind="visible: totalPages() > 1">
                <ul class="pagination justify-content-center mt-4">
                    <li class="page-item" data-bind="css: { disabled: currentPage() === 1 }">
                        <a class="page-link" href="#" data-bind="click: previousPage">Previous</a>
                    </li>
                    <!-- ko foreach: pageNumbers -->
                    <li class="page-item" data-bind="css: { active: $data === $parent.currentPage() }">
                        <a class="page-link" href="#" data-bind="text: $data, click: function() { $parent.goToPage($data); }"></a>
                    </li>
                    <!-- /ko -->
                    <li class="page-item" data-bind="css: { disabled: currentPage() === totalPages() }">
                        <a class="page-link" href="#" data-bind="click: nextPage">Next</a>
                    </li>
                </ul>
                <p class="text-center text-muted">
                    Page <span data-bind="text: currentPage"></span> of <span data-bind="text: totalPages"></span>
                    (<span data-bind="text: totalCount"></span> total videos)
                </p>
            </nav>
        </div>
    </div>
</div>

@section Scripts {
    <script type="module" src="~/js/downloads.js"></script>
}