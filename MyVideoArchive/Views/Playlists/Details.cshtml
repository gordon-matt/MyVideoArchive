@{
    ViewData["Title"] = "Playlist";
    var playlistId = ViewBag.PlaylistId;
}

@section Styles {
    <link rel="stylesheet" href="~/css/playlist-details.css" asp-append-version="true" />
}

<div class="container-fluid px-0">
    <div class="row g-0" data-bind="visible: playlist()">
        <div class="col-lg-8">
            <!-- Current Video Player -->
            <div id="video-player-container" class="bg-dark">
                <div class="player-placeholder" data-bind="visible: !currentVideo()">
                    <i class="bi bi-collection-play display-4 mb-3 opacity-50"></i>
                    <h5>Select a video from the playlist</h5>
                    <p class="text-white-50 small mb-0">Click any video in the sidebar to start watching</p>
                </div>
                <video id="videoPlayer"
                       class="video-js vjs-default-skin vjs-big-play-centered"
                       controls
                       preload="auto">
                </video>
            </div>
            
            <!-- Current Video Info -->
            <div class="card mt-3" data-bind="visible: currentVideo()">
                <div class="card-body">
                    <h3 class="card-title" data-bind="text: currentVideo() && currentVideo().title"></h3>
                    
                    <div class="d-flex align-items-center mb-3 text-muted">
                        <span data-bind="if: currentVideo() && currentVideo().viewCount">
                            <i class="bi bi-eye"></i> <span data-bind="text: formatNumber(currentVideo().viewCount)"></span> views
                        </span>
                        <span data-bind="if: currentVideo() && currentVideo().likeCount" class="ms-3">
                            <i class="bi bi-hand-thumbs-up"></i> <span data-bind="text: formatNumber(currentVideo().likeCount)"></span> likes
                        </span>
                        <span data-bind="if: currentVideo() && currentVideo().uploadDate" class="ms-3">
                            <i class="bi bi-calendar"></i> <span data-bind="text: formatDate(currentVideo().uploadDate)"></span>
                        </span>
                    </div>
                    
                    <div class="description-box p-3 bg-light rounded">
                        <p class="mb-0" data-bind="text: currentVideo() && currentVideo().description" style="white-space: pre-wrap;"></p>
                    </div>
                </div>
            </div>

            <!-- Video Information -->
            <div class="card mt-3" data-bind="visible: currentVideo()">
                <div class="card-header">
                    <h5 class="mb-0">Video Information</h5>
                </div>
                <div class="card-body">
                    <table class="table table-sm">
                        <tbody>
                            <tr data-bind="if: currentVideo() && currentVideo().duration">
                                <th>Duration</th>
                                <td data-bind="text: formatDuration(currentVideo().duration)"></td>
                            </tr>
                            <tr data-bind="if: currentVideo() && currentVideo().downloadedAt">
                                <th>Downloaded</th>
                                <td data-bind="text: formatDate(currentVideo().downloadedAt)"></td>
                            </tr>
                            <tr data-bind="if: currentVideo() && currentVideo().url">
                                <th>Original URL</th>
                                <td>
                                    <a data-bind="attr: { href: currentVideo().url }" target="_blank" class="text-truncate d-block" style="max-width: 200px;">Open Original</a>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                    <div class="mt-3">
                        <h6 class="mb-1"><i class="bi bi-tags"></i> Video tags</h6>
                        <input id="playlistPageVideoTagsInput" class="form-control form-control-sm" placeholder="Add tags..." />
                        <div class="form-text">Press Enter or comma to add a tag. Changes are saved automatically.</div>
                    </div>
                </div>
            </div>
        </div>
        
        <div class="col-lg-4">
            <!-- Playlist Info & Video List -->
            <div class="playlist-sidebar">
                <div class="card mb-3">
                    <div class="card-header bg-primary text-white">
                        <h5 class="mb-0" data-bind="text: playlist() && playlist().Name"></h5>
                        <small data-bind="text: (playlist() && playlist().Channel ? playlist().Channel.Name : '')"></small>
                    </div>
                    <div class="card-body">
                        <p class="text-muted small mb-2" data-bind="text: playlist() && playlist().Description"></p>
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <span><strong><span data-bind="text: visibleVideoCount()"></span></strong> videos</span>
                            <div class="d-flex gap-2">
                                <button class="btn btn-sm btn-outline-secondary"
                                        data-bind="click: refreshFromSource, enable: !refreshing()">
                                    <span data-bind="visible: !refreshing()">
                                        <i class="bi bi-arrow-clockwise"></i> Refresh
                                    </span>
                                    <span data-bind="visible: refreshing()">
                                        <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                                        Refreshing...
                                    </span>
                                </button>
                                <button class="btn btn-sm btn-primary" data-bind="click: openDownloadAllModal, visible: hasDownloadableVideos()">
                                    <i class="bi bi-cloud-download"></i> Download All
                                </button>
                                <a data-bind="attr: { href: '/channels/' + (playlist() && playlist().ChannelId) }" class="btn btn-sm btn-outline-primary">View Channel</a>
                            </div>
                        </div>
                        
                        <!-- Order Toggle -->
                        <div class="form-check form-switch mb-2">
                            <input class="form-check-input" type="checkbox" id="useCustomOrderSwitch" data-bind="checked: useCustomOrder, click: toggleOrderMode">
                            <label class="form-check-label" for="useCustomOrderSwitch">
                                <span data-bind="text: useCustomOrder() ? 'My Custom Order' : 'Original Order'"></span>
                            </label>
                        </div>
                        
                        <div data-bind="visible: useCustomOrder" class="mb-2">
                            <small class="text-muted"><i class="bi bi-info-circle"></i> Drag videos to reorder</small>
                        </div>

                        <!-- Show Hidden Toggle -->
                        <div class="form-check form-switch mb-2">
                            <input class="form-check-input" type="checkbox" id="showHiddenSwitch" data-bind="checked: showHidden, click: toggleShowHidden">
                            <label class="form-check-label" for="showHiddenSwitch">
                                Show Hidden Videos
                            </label>
                        </div>

                        <!-- Auto-advance Toggle -->
                        <div class="form-check form-switch mb-3">
                            <input class="form-check-input" type="checkbox" id="autoAdvanceSwitch" data-bind="checked: autoAdvance">
                            <label class="form-check-label" for="autoAdvanceSwitch">
                                <i class="bi bi-skip-end-fill me-1"></i> Auto-advance
                            </label>
                        </div>
                        <div>
                            <label class="form-label small text-uppercase fw-semibold mb-1">
                                <i class="bi bi-tags"></i> Tags
                            </label>
                            <input id="playlistTagsInput" class="form-control form-control-sm" placeholder="Add tags..." />
                            <div class="form-text">Press Enter or comma to add a tag. Changes are saved automatically.</div>
                        </div>
                    </div>
                </div>
                
                <div class="video-list">
                    <div data-bind="visible: loadingVideos" class="text-center py-3">
                        <div class="spinner-border spinner-border-sm" role="status">
                            <span class="visually-hidden">Loading...</span>
                        </div>
                    </div>
                    
                    <div data-bind="visible: !loadingVideos() && playlistVideos().length === 0" class="alert alert-info">
                        <p class="small mb-0">No videos in this playlist yet.</p>
                    </div>
                    
                    <div id="videoListContainer" data-bind="visible: !loadingVideos() && playlistVideos().length > 0, foreach: playlistVideos">
                    <div class="playlist-video-item" data-bind="click: $parent.playVideo, css: { active: $parent.currentVideo() && $parent.currentVideo().id === id, 'not-downloaded': !downloadedAt }, attr: { 'data-video-id': id }">
                        <span data-bind="visible: $parent.useCustomOrder()" class="drag-handle">
                            <i class="bi bi-grip-vertical"></i>
                        </span>
                        <img data-bind="attr: { src: thumbnailUrl || 'https://placehold.co/120x68?text=No+Thumbnail', alt: title }" class="playlist-video-thumbnail" />
                            <div class="playlist-video-info flex-grow-1">
                                <div class="playlist-video-title">
                                    <span data-bind="text: title"></span>
                                    <!-- ko if: watched -->
                                    <i class="bi bi-eye text-success ms-1" title="Watched"></i>
                                    <!-- /ko -->
                                    <!-- ko if: isHidden -->
                                    <span class="badge bg-warning text-dark ms-1">Hidden</span>
                                    <!-- /ko -->
                                </div>
                                <!-- ko if: channel -->
                                <div class="playlist-video-channel" data-bind="text: channel.name"></div>
                                <!-- /ko -->
                                <!-- ko if: duration -->
                                <small class="text-muted" data-bind="text: $parent.formatDuration(duration)"></small>
                                <!-- /ko -->
                                <!-- ko if: !downloadedAt -->
                                <div class="mt-1 d-flex align-items-center gap-1">
                                    <!-- ko if: downloadFailed -->
                                    <span class="badge bg-danger small"><i class="bi bi-exclamation-triangle-fill"></i> Failed</span>
                                    <!-- /ko -->
                                    <!-- ko ifnot: downloadFailed -->
                                    <span class="badge bg-warning text-dark small" data-bind="visible: !isQueued">Not Downloaded</span>
                                    <span class="badge bg-info text-dark small" data-bind="visible: isQueued">Downloading...</span>
                                    <!-- /ko -->
                                    <!-- ko if: url -->
                                    <a data-bind="attr: { href: url }" target="_blank" class="text-muted" title="View original" onclick="event.stopPropagation();">
                                        <i class="bi bi-box-arrow-up-right small"></i>
                                    </a>
                                    <!-- /ko -->
                                </div>
                                <!-- /ko -->
                            </div>
                            <div class="d-flex flex-column gap-1 ms-2" onclick="event.stopPropagation()">
                                <!-- ko if: isHidden -->
                                <button class="btn btn-sm btn-outline-warning" title="Unhide" data-bind="click: function(data, event) { event.stopPropagation(); $parent.unhideVideo(data); }">
                                    <i class="bi bi-eye"></i>
                                </button>
                                <!-- /ko -->
                                <!-- ko ifnot: isHidden -->
                                <button class="btn btn-sm btn-outline-secondary" title="Hide" data-bind="click: function(data, event) { event.stopPropagation(); $parent.hideVideo(data); }">
                                    <i class="bi bi-eye-slash"></i>
                                </button>
                                <!-- /ko -->
                                <!-- ko if: !downloadedAt && !downloadFailed && title != '@Constants.PrivateVideoTitle' && title != '@Constants.DeletedVideoTitle' -->
                                <button class="btn btn-sm btn-primary" data-bind="click: function(data, event) { event.stopPropagation(); $parent.downloadVideo(data, event); }">
                                    <i class="bi bi-download"></i>
                                </button>
                                <!-- /ko -->
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <div data-bind="visible: loading" class="text-center py-5">
        <div class="spinner-border" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
    
    <div data-bind="visible: !loading() && !playlist()" class="text-center py-5">
        <h3>Playlist not found</h3>
        <p>This playlist may not exist or you may not have access to it.</p>
        <a href="/channels" class="btn btn-primary">Back to Channels</a>
    </div>
</div>

<!-- Download All Modal -->
<div class="modal fade" id="downloadAllModal" tabindex="-1" aria-labelledby="downloadAllModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="downloadAllModalLabel">
                    <i class="bi bi-cloud-download me-2"></i>Download Videos
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close" data-bind="enable: !downloadingAll()"></button>
            </div>
            <div class="modal-body">
                <div class="d-flex align-items-center justify-content-between mb-3">
                    <span class="text-muted small">
                        <span data-bind="text: downloadAllModalVideos().filter(v => v.selectedForDownload()).length"></span>
                        of <span data-bind="text: downloadAllModalVideos().length"></span> selected
                    </span>
                    <div class="form-check form-check-inline mb-0">
                        <input class="form-check-input" type="checkbox" id="downloadAllSelectAll" data-bind="checked: downloadAllSelectAll">
                        <label class="form-check-label" for="downloadAllSelectAll">Select All</label>
                    </div>
                </div>

                <div data-bind="visible: downloadAllModalVideos().length === 0" class="alert alert-info">
                    All videos in this playlist are already downloaded or queued.
                </div>

                <div data-bind="foreach: downloadAllModalVideos" class="list-group">
                    <label class="list-group-item list-group-item-action d-flex align-items-center gap-3 py-2">
                        <input type="checkbox" class="form-check-input flex-shrink-0" data-bind="checked: selectedForDownload">
                        <img data-bind="attr: { src: thumbnailUrl || 'https://placehold.co/80x45?text=No+Thumbnail', alt: title }"
                             style="width: 80px; height: 45px; object-fit: cover; border-radius: 4px; flex-shrink: 0;">
                        <div class="flex-grow-1 min-width-0">
                            <div class="fw-medium text-truncate" data-bind="text: title"></div>
                            <small class="text-muted" data-bind="if: duration">
                                <span data-bind="text: $parent.formatDuration(duration)"></span>
                            </small>
                        </div>
                    </label>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal" data-bind="enable: !downloadingAll()">Cancel</button>
                <button type="button" class="btn btn-primary"
                        data-bind="click: confirmDownloadAll, enable: !downloadingAll() && downloadAllModalVideos().some(v => v.selectedForDownload())">
                    <span data-bind="visible: !downloadingAll()">
                        <i class="bi bi-download me-1"></i>
                        Download <span data-bind="text: downloadAllModalVideos().filter(v => v.selectedForDownload()).length"></span> Video(s)
                    </span>
                    <span data-bind="visible: downloadingAll()">
                        <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                        Queueing&hellip;
                    </span>
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <environment include="Development">
        <script src="~/lib/sortablejs/Sortable.js"></script>
    </environment>
    <environment exclude="Development">
        <script src="~/lib/sortablejs/Sortable.min.js"></script>
    </environment>

    <script type="text/javascript">
        const playlistId = @playlistId;
        const PRIVATE_VIDEO_TITLE = '@MyVideoArchive.Constants.PrivateVideoTitle';
        const DELETED_VIDEO_TITLE = '@MyVideoArchive.Constants.DeletedVideoTitle';
    </script>
    <script type="module" src="~/js/playlist-details.js" asp-append-version="true"></script>
}
