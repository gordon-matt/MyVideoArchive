@{
    ViewData["Title"] = "Playlist";
    var playlistId = ViewBag.PlaylistId;
}

@section Styles {
    <link rel="stylesheet" href="~/css/playlist-details.css" />
}

<div class="container-fluid px-0">
    <div class="row g-0" data-bind="visible: playlist()">
        <div class="col-lg-8">
            <!-- Current Video Player -->
            <div id="video-player-container" class="bg-dark" style="min-height: 400px;">
                <div class="text-center text-white py-5" data-bind="visible: !currentVideo()">
                    <h3>Select a video from the playlist</h3>
                    <p>Click on any video in the playlist to start watching</p>
                </div>
                
                <div data-bind="visible: currentVideo()">
                    <video id="videoPlayer" class="w-100" controls data-bind="attr: { src: currentVideoUrl }">
                        Your browser does not support the video tag.
                    </video>
                </div>
            </div>
            
            <!-- Current Video Info -->
            <div class="card mt-3" data-bind="visible: currentVideo()">
                <div class="card-body">
                    <h3 class="card-title" data-bind="text: currentVideo() && currentVideo().title"></h3>
                    
                    <div class="d-flex align-items-center mb-3 text-muted">
                        <span data-bind="if: currentVideo() && currentVideo().viewCount">
                            <i class="bi bi-eye"></i> <span data-bind="text: formatNumber(currentVideo().viewCount)"></span> views
                        </span>
                        <span data-bind="if: currentVideo() && currentVideo().likeCount" class="ms-3">
                            <i class="bi bi-hand-thumbs-up"></i> <span data-bind="text: formatNumber(currentVideo().likeCount)"></span> likes
                        </span>
                        <span data-bind="if: currentVideo() && currentVideo().uploadDate" class="ms-3">
                            <i class="bi bi-calendar"></i> <span data-bind="text: formatDate(currentVideo().uploadDate)"></span>
                        </span>
                    </div>
                    
                    <div class="description-box p-3 bg-light rounded">
                        <p class="mb-0" data-bind="text: currentVideo() && currentVideo().description" style="white-space: pre-wrap;"></p>
                    </div>
                </div>
            </div>

            <!-- Video Information -->
            <div class="card mt-3" data-bind="visible: currentVideo()">
                <div class="card-header">
                    <h5 class="mb-0">Video Information</h5>
                </div>
                <div class="card-body">
                    <table class="table table-sm">
                        <tbody>
                            <tr data-bind="if: currentVideo() && currentVideo().duration">
                                <th>Duration</th>
                                <td data-bind="text: formatDuration(currentVideo().duration)"></td>
                            </tr>
                            <tr data-bind="if: currentVideo() && currentVideo().downloadedAt">
                                <th>Downloaded</th>
                                <td data-bind="text: formatDate(currentVideo().downloadedAt)"></td>
                            </tr>
                            <tr data-bind="if: currentVideo() && currentVideo().url">
                                <th>Original URL</th>
                                <td>
                                    <a data-bind="attr: { href: currentVideo().url }" target="_blank" class="text-truncate d-block" style="max-width: 200px;">Open Original</a>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
        
        <div class="col-lg-4">
            <!-- Playlist Info & Video List -->
            <div class="playlist-sidebar">
                <div class="card mb-3">
                    <div class="card-header bg-primary text-white">
                        <h5 class="mb-0" data-bind="text: playlist() && playlist().Name"></h5>
                        <small data-bind="text: (playlist() && playlist().Channel ? playlist().Channel.Name : '')"></small>
                    </div>
                    <div class="card-body">
                        <p class="text-muted small mb-2" data-bind="text: playlist() && playlist().Description"></p>
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <span><strong><span data-bind="text: visibleVideoCount()"></span></strong> videos</span>
                            <a data-bind="attr: { href: '/channels/' + (playlist() && playlist().ChannelId) }" class="btn btn-sm btn-outline-primary">View Channel</a>
                        </div>
                        
                        <!-- Order Toggle -->
                        <div class="form-check form-switch mb-2">
                            <input class="form-check-input" type="checkbox" id="useCustomOrderSwitch" data-bind="checked: useCustomOrder, click: toggleOrderMode">
                            <label class="form-check-label" for="useCustomOrderSwitch">
                                <span data-bind="text: useCustomOrder() ? 'My Custom Order' : 'Original Order'"></span>
                            </label>
                        </div>
                        
                        <div data-bind="visible: useCustomOrder" class="mb-2">
                            <small class="text-muted"><i class="bi bi-info-circle"></i> Drag videos to reorder</small>
                        </div>

                        <!-- Show Hidden Toggle -->
                        <div class="form-check form-switch">
                            <input class="form-check-input" type="checkbox" id="showHiddenSwitch" data-bind="checked: showHidden, click: toggleShowHidden">
                            <label class="form-check-label" for="showHiddenSwitch">
                                Show Hidden Videos
                            </label>
                        </div>
                    </div>
                </div>
                
                <div class="video-list">
                    <div data-bind="visible: loadingVideos" class="text-center py-3">
                        <div class="spinner-border spinner-border-sm" role="status">
                            <span class="visually-hidden">Loading...</span>
                        </div>
                    </div>
                    
                    <div data-bind="visible: !loadingVideos() && playlistVideos().length === 0" class="alert alert-info">
                        <p class="small mb-0">No videos in this playlist yet.</p>
                    </div>
                    
                    <div id="videoListContainer" data-bind="visible: !loadingVideos() && playlistVideos().length > 0, foreach: playlistVideos">
                    <div class="playlist-video-item" data-bind="click: $parent.playVideo, css: { active: $parent.currentVideo() && $parent.currentVideo().id === id, 'not-downloaded': !downloadedAt }, attr: { 'data-video-id': id }">
                        <span data-bind="visible: $parent.useCustomOrder()" class="drag-handle">
                            <i class="bi bi-grip-vertical"></i>
                        </span>
                        <img data-bind="attr: { src: thumbnailUrl || 'https://placehold.co/120x68?text=No+Thumbnail', alt: title }" class="playlist-video-thumbnail" />
                            <div class="playlist-video-info flex-grow-1">
                                <div class="playlist-video-title">
                                    <span data-bind="text: title"></span>
                                    <!-- ko if: watched -->
                                    <i class="bi bi-eye text-success ms-1" title="Watched"></i>
                                    <!-- /ko -->
                                    <!-- ko if: isHidden -->
                                    <span class="badge bg-warning text-dark ms-1">Hidden</span>
                                    <!-- /ko -->
                                </div>
                                <!-- ko if: channel -->
                                <div class="playlist-video-channel" data-bind="text: channel.name"></div>
                                <!-- /ko -->
                                <!-- ko if: duration -->
                                <small class="text-muted" data-bind="text: $parent.formatDuration(duration)"></small>
                                <!-- /ko -->
                                <!-- ko if: !downloadedAt -->
                                <div class="mt-1">
                                    <!-- ko if: downloadFailed -->
                                    <span class="badge bg-danger small"><i class="bi bi-exclamation-triangle-fill"></i> Failed</span>
                                    <!-- /ko -->
                                    <!-- ko ifnot: downloadFailed -->
                                    <span class="badge bg-warning text-dark small" data-bind="visible: !isQueued">Not Downloaded</span>
                                    <span class="badge bg-info text-dark small" data-bind="visible: isQueued">Downloading...</span>
                                    <!-- /ko -->
                                </div>
                                <!-- /ko -->
                            </div>
                            <div class="d-flex flex-column gap-1 ms-2" onclick="event.stopPropagation()">
                                <!-- ko if: isHidden -->
                                <button class="btn btn-sm btn-outline-warning" title="Unhide" data-bind="click: function(data, event) { event.stopPropagation(); $parent.unhideVideo(data); }">
                                    <i class="bi bi-eye"></i>
                                </button>
                                <!-- /ko -->
                                <!-- ko ifnot: isHidden -->
                                <button class="btn btn-sm btn-outline-secondary" title="Hide" data-bind="click: function(data, event) { event.stopPropagation(); $parent.hideVideo(data); }">
                                    <i class="bi bi-eye-slash"></i>
                                </button>
                                <!-- /ko -->
                                <!-- ko if: !downloadedAt && !downloadFailed && title != '@Constants.PrivateVideoTitle' && title != '@Constants.DeletedVideoTitle' -->
                                <button class="btn btn-sm btn-primary" data-bind="click: function(data, event) { event.stopPropagation(); $parent.downloadVideo(data, event); }">
                                    <i class="bi bi-download"></i>
                                </button>
                                <!-- /ko -->
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <div data-bind="visible: loading" class="text-center py-5">
        <div class="spinner-border" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
    
    <div data-bind="visible: !loading() && !playlist()" class="text-center py-5">
        <h3>Playlist not found</h3>
        <p>This playlist may not exist or you may not have access to it.</p>
        <a href="/channels" class="btn btn-primary">Back to Channels</a>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.0/Sortable.min.js"></script>
    <script type="text/javascript">
        const playlistId = @playlistId;
    </script>
    <script type="module" src="~/js/playlist-details.js"></script>
}
