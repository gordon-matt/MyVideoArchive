@{
    ViewData["Title"] = "Series";
    var seriesId = ViewBag.SeriesId;
    var isAdminUser = User.IsInRole(Constants.Roles.Administrator);
}

@section Styles {
    <link rel="stylesheet" href="~/css/playlist-details.css" asp-append-version="true" />
    <style>
        .series-playlist-item {
            display: flex;
            align-items: center;
            padding: 10px 12px;
            border-bottom: 1px solid var(--bs-border-color);
            transition: background 0.15s;
            cursor: default;
        }
        .series-playlist-item:last-child { border-bottom: none; }
        .series-playlist-item:hover { background: rgba(0,0,0,.03); }
        .series-playlist-thumbnail {
            width: 80px;
            height: 45px;
            object-fit: cover;
            border-radius: 4px;
            flex-shrink: 0;
        }
        .series-playlist-info { flex: 1; min-width: 0; }
    </style>
}

<div data-bind="with: series">

    <div class="d-flex align-items-center gap-3 mb-4">
        <a data-bind="attr: { href: '/channels/' + channelId }" class="btn btn-outline-secondary btn-sm">
            &larr; Back to Channel
        </a>
        @if (isAdminUser)
        {
            <button class="btn btn-sm btn-outline-secondary ms-auto" data-bind="click: $parent.openEditSeries">
                <i class="bi bi-pencil"></i> Edit Series
            </button>
        }
    </div>

    <h2 class="mb-1" data-bind="text: name"></h2>
    <p class="text-muted mb-4">
        <span data-bind="text: playlists.length"></span>
        <span data-bind="text: playlists.length === 1 ? ' playlist' : ' playlists'"></span>
        @if (isAdminUser)
        {
            <text> &mdash; <small><i class="bi bi-grip-vertical"></i> Drag rows to reorder</small></text>
        }
    </p>

    <!-- Playlist list -->
    <div data-bind="visible: playlists.length === 0" class="alert alert-info">
        No playlists in this series yet.
    </div>

    <div class="card" data-bind="visible: playlists.length > 0">
        <div id="seriesPlaylistList" data-bind="foreach: playlists">
            <div class="series-playlist-item" data-bind="attr: { 'data-playlist-id': id }">
                @if (isAdminUser)
                {
                    <span class="drag-handle me-2">
                        <i class="bi bi-grip-vertical"></i>
                    </span>
                }
                <!-- ko if: thumbnailUrl -->
                <img data-bind="attr: { src: thumbnailUrl, alt: name }" class="series-playlist-thumbnail me-3" />
                <!-- /ko -->
                <!-- ko ifnot: thumbnailUrl -->
                <div class="series-playlist-thumbnail me-3 d-flex align-items-center justify-content-center bg-secondary rounded">
                    <i class="bi bi-collection-play text-white"></i>
                </div>
                <!-- /ko -->
                <div class="series-playlist-info">
                    <a data-bind="attr: { href: '/playlists/' + id }, text: name"
                       class="text-decoration-none fw-semibold"></a>
                </div>
                <div class="ms-3 text-muted small">
                    #<span data-bind="text: $index() + 1"></span>
                </div>
            </div>
        </div>
    </div>

</div>

<!-- Loading state -->
<div data-bind="visible: loading" class="text-center py-5">
    <div class="spinner-border" role="status">
        <span class="visually-hidden">Loading&hellip;</span>
    </div>
</div>

<!-- Saving indicator -->
<div class="position-fixed bottom-0 end-0 p-3" style="z-index: 1050;" data-bind="visible: saving">
    <div class="toast show align-items-center text-white bg-secondary border-0">
        <div class="d-flex">
            <div class="toast-body">
                <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                Saving order&hellip;
            </div>
        </div>
    </div>
</div>

<!-- Edit modal (admin only) -->
@if (isAdminUser)
{
    @await Html.PartialAsync("_SeriesModals")
}

@section Scripts {
    <script type="text/javascript">
        var seriesId = @seriesId;
        var isAdmin = @(isAdminUser ? "true" : "false");
    </script>
    @if (isAdminUser)
    {
        <environment include="Development">
            <script src="~/lib/sortablejs/Sortable.js"></script>
        </environment>
        <environment exclude="Development">
            <script src="~/lib/sortablejs/Sortable.min.js"></script>
        </environment>
    }
    <script type="module" src="~/js/series-details.js" asp-append-version="true"></script>
}
