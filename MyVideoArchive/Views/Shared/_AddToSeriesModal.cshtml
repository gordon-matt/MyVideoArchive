<!-- Add Playlist to Series modal (from playlist details page) -->
<div class="modal fade" id="addToSeriesModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-collection me-2"></i>Add to Series</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div data-bind="visible: addToSeriesLoading" class="text-center py-3">
                    <div class="spinner-border spinner-border-sm" role="status"></div>
                </div>
                <div data-bind="visible: !addToSeriesLoading()">
                    <div data-bind="visible: addToSeriesOptions().length > 0" class="list-group mb-3">
                        <!-- ko foreach: addToSeriesOptions -->
                        <button type="button" class="list-group-item list-group-item-action d-flex align-items-center gap-2 py-2"
                                data-bind="click: $parent.addToExistingSeries">
                            <i class="bi bi-collection me-1"></i>
                            <span data-bind="text: name"></span>
                            <!-- ko if: $parent.playlistIsInSeries(id) -->
                            <span class="badge bg-success ms-auto">Already added</span>
                            <!-- /ko -->
                        </button>
                        <!-- /ko -->
                    </div>
                    <hr class="my-2" data-bind="visible: addToSeriesOptions().length > 0" />
                    <button class="btn btn-outline-primary w-100" data-bind="click: openNewSeriesInline">
                        <i class="bi bi-plus-circle me-1"></i> Create new series&hellip;
                    </button>
                    <div class="mt-3" data-bind="visible: addToSeriesShowNewForm">
                        <input type="text" class="form-control" placeholder="Series name…"
                               data-bind="value: addToSeriesNewName, valueUpdate: 'input'" />
                        <div class="d-flex gap-2 mt-2">
                            <button class="btn btn-primary btn-sm"
                                    data-bind="click: createSeriesAndAdd, enable: addToSeriesNewName().trim().length > 0 && !addToSeriesCreating()">
                                <span data-bind="visible: !addToSeriesCreating()">Create &amp; Add</span>
                                <span data-bind="visible: addToSeriesCreating()">
                                    <span class="spinner-border spinner-border-sm" role="status"></span>
                                </span>
                            </button>
                            <button class="btn btn-outline-secondary btn-sm" data-bind="click: function(){ addToSeriesShowNewForm(false); }">
                                Cancel
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
