@model bool
@{
    bool isAdmin = Model;
}

<div class="mb-3 d-flex flex-wrap gap-3 justify-content-between align-items-center">
    <div class="d-flex flex-wrap gap-3 align-items-center flex-grow-1">
        <div class="input-group" style="max-width: 340px;">
            <input type="text" id="extrasSearchInput" class="form-control" placeholder="Search by name…"
                   data-bind="value: extrasSearchInput, valueUpdate: 'input'" />
            <button class="btn btn-outline-secondary" data-bind="click: clearExtrasSearch, visible: extrasSearchInput().length > 0"
                    title="Clear search" type="button">
                <i class="bi bi-x-lg"></i>
            </button>
        </div>
        <div class="form-check mb-0">
            <input class="form-check-input" type="checkbox" id="extrasOnlyUnassigned"
                   data-bind="checked: extrasOnlyUnassigned" />
            <label class="form-check-label" for="extrasOnlyUnassigned">Only Show Unassigned</label>
        </div>
    </div>
    @if (isAdmin)
    {
        <button class="btn btn-primary" data-bind="click: openUploadExtras">
            <i class="bi bi-upload"></i> Upload
        </button>
    }
</div>

<div data-bind="visible: extrasLoading" class="text-center py-3">
    <div class="spinner-border spinner-border-sm" role="status">
        <span class="visually-hidden">Loading&hellip;</span>
    </div>
</div>

<div data-bind="visible: !extrasLoading() && extrasItems().length === 0" class="alert alert-info">
    No additional content yet.
    @if (isAdmin)
    {
        <text>Click "Upload" to add files.</text>
    }
</div>

<div data-bind="visible: !extrasLoading() && extrasItems().length > 0 && filteredExtrasItems().length === 0" class="alert alert-info">
    No items match the current filters.
</div>

<div data-bind="visible: !extrasLoading() && filteredExtrasItems().length > 0">
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead class="table-light">
                <tr>
                    <th>Item</th>
                    <th>Path</th>
                    <th>Playlists</th>
                    <th>Size</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody data-bind="foreach: filteredExtrasItems">
                <tr>
                    <td>
                        <i class="bi bi-file-earmark me-1 text-muted"></i>
                        <!-- ko if: $parent.isPreviewableExtraName && $parent.isPreviewableExtraName(fileName) -->
                        <a href="#" class="link-body-emphasis"
                           data-bind="text: fileName, click: function(row) { $parent.openPreviewExtra(row); return false; }"></a>
                        <!-- /ko -->
                        <!-- ko ifnot: $parent.isPreviewableExtraName && $parent.isPreviewableExtraName(fileName) -->
                        <a data-bind="attr: { href: '/api/additional-content/' + id + '/download' }, text: fileName"
                           target="_blank" rel="noopener noreferrer"
                           class="link-body-emphasis"></a>
                        <!-- /ko -->
                        <small class="text-muted ms-1" data-bind="text: contentType ? '(' + contentType + ')' : ''"></small>
                    </td>
                    <td class="text-muted small text-break" data-bind="text: relativePath || '—'"></td>
                    <td>
                        <span data-bind="text: $parent.formatExtrasPlaylistNames($data)"></span>
                    </td>
                    <td class="text-nowrap text-muted small">
                        <span data-bind="text: $parent.formatFileSize(fileSize)"></span>
                    </td>
                    <td class="text-nowrap">
                        <a class="btn btn-sm btn-outline-secondary me-1"
                           data-bind="attr: { href: '/api/additional-content/' + id + '/download?isForDownload=true' }"
                           target="_blank" title="Download">
                            <i class="bi bi-download"></i>
                        </a>
                        @if (isAdmin)
                        {
                            <button class="btn btn-sm btn-outline-primary me-1"
                                    data-bind="click: $parent.openEditExtras" title="Edit">
                                <i class="bi bi-pencil"></i>
                            </button>
                            <button class="btn btn-sm btn-outline-danger"
                                    data-bind="click: $parent.deleteExtras" title="Delete">
                                <i class="bi bi-trash"></i>
                            </button>
                        }
                    </td>
                </tr>
            </tbody>
        </table>
    </div>
</div>
