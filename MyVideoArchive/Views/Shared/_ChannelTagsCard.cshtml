@* Shared by channel Details and DetailsCustom; Tagify targets #channelTagsInput *@
<div class="row mb-4">
    <div class="col-12">
        <div class="card">
            <div class="card-header">
                <h6 class="mb-0"><i class="bi bi-tags"></i> Tags</h6>
            </div>
            <div class="card-body">
                <input id="channelTagsInput" class="form-control" placeholder="Add tags..." />
                <div class="form-text">Press Enter or comma to add a tag. Changes are saved automatically.</div>
            </div>
        </div>
    </div>
</div>
