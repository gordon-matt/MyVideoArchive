@using MyVideoArchive.Infrastructure
@inject IAuthProviderService AuthProvider

<ul class="navbar-nav">
@if (User.Identity?.IsAuthenticated == true)
{
    <li class="nav-item">
        @if (AuthProvider.IsKeycloak)
        {
            @* Keycloak: link to Keycloak's self-service account console *@
            <a class="nav-link text-dark" href="@AuthProvider.KeycloakAccountUrl" target="_blank" rel="noopener" title="Manage account in Keycloak">Hello @User.Identity?.Name!</a>
        }
        else
        {
            <a class="nav-link text-dark" asp-area="Identity" asp-page="/Account/Manage/Index" title="Manage">Hello @User.Identity?.Name!</a>
        }
    </li>
    <li class="nav-item">
        @if (AuthProvider.IsKeycloak)
        {
            @* Keycloak: POST to AuthController which signs out of both cookie and OIDC session *@
            <form class="form-inline" asp-controller="Auth" asp-action="Logout" asp-area="">
                @Html.AntiForgeryToken()
                <button type="submit" class="nav-link btn btn-link text-dark">Logout</button>
            </form>
        }
        else
        {
            <form class="form-inline" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
                <button type="submit" class="nav-link btn btn-link text-dark">Logout</button>
            </form>
        }
    </li>
}
else
{
    @if (!AuthProvider.IsKeycloak)
    {
        @* Identity only: self-registration is not applicable when using Keycloak *@
        <li class="nav-item">
            <a class="nav-link text-dark" asp-area="Identity" asp-page="/Account/Register">Register</a>
        </li>
    }
    <li class="nav-item">
        @if (AuthProvider.IsKeycloak)
        {
            <a class="nav-link text-dark" asp-controller="Auth" asp-action="Login" asp-area="" asp-route-returnUrl="@Context.Request.Path">Login</a>
        }
        else
        {
            <a class="nav-link text-dark" asp-area="Identity" asp-page="/Account/Login">Login</a>
        }
    </li>
}
</ul>
