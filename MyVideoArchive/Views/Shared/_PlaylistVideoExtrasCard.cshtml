@model bool
@* isAdminUser: show admin-only associate / remove controls *@
<div class="card mt-3" data-bind="visible: currentVideo()">
    <div class="card-header d-flex flex-wrap justify-content-between align-items-center gap-2">
        <h6 class="mb-0"><i class="bi bi-paperclip me-1"></i>Extras for this video</h6>
        @if (Model)
        {
            <button type="button" class="btn btn-sm btn-outline-primary"
                    data-bind="click: openVideoExtrasPicker, disable: extrasPickerLoading">
                <i class="bi bi-plus-lg me-1"></i>Associate items&hellip;
            </button>
        }
    </div>
    <div class="card-body p-2">
        <div data-bind="visible: extrasLoading" class="text-center py-2">
            <div class="spinner-border spinner-border-sm" role="status"></div>
        </div>
        <div data-bind="visible: !extrasLoading() && extrasItems().length === 0" class="text-muted small p-2">
            No additional files linked to this video yet.
            @if (Model)
            {
                <text>Use &quot;Associate items&hellip;&quot; to pick from files available for this playlist.</text>
            }
        </div>
        <div data-bind="visible: !extrasLoading() && extrasItems().length > 0">
            <div class="table-responsive">
                <table class="table table-sm table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Item</th>
                            <th class="playlist-video-extras-actions">Actions</th>
                        </tr>
                    </thead>
                    <tbody data-bind="foreach: extrasItems">
                        <tr>
                            <td>
                                <i class="bi bi-file-earmark me-1 text-muted"></i>
                                <a data-bind="attr: { href: '/api/additional-content/' + id + '/download' }, text: fileName"
                                   target="_blank" rel="noopener noreferrer"
                                   class="link-body-emphasis"></a>
                            </td>
                            <td class="playlist-video-extras-actions">
                                <a class="btn btn-sm btn-outline-secondary"
                                   data-bind="attr: { href: '/api/additional-content/' + id + '/download?isForDownload=true' }"
                                   target="_blank" title="Download">
                                    <i class="bi bi-download"></i>
                                </a>
                                @if (Model)
                                {
                                    <button class="btn btn-sm btn-outline-warning ms-1"
                                            data-bind="click: $parent.removeVideoExtra" title="Remove from this video">
                                        <i class="bi bi-link-45deg"></i>
                                    </button>
                                }
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
