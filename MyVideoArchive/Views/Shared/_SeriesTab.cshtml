@model bool
@{
    bool isAdmin = Model;
}

<div class="mb-3 d-flex justify-content-between align-items-center">
    @if (isAdmin)
    {
        <button class="btn btn-primary" data-bind="click: openCreateSeries">
            <i class="bi bi-plus-circle"></i> Create Series
        </button>
    }
    else
    {
        <span></span>
    }
</div>

<div data-bind="visible: seriesLoading" class="text-center py-3">
    <div class="spinner-border spinner-border-sm" role="status">
        <span class="visually-hidden">Loading&hellip;</span>
    </div>
</div>

<div data-bind="visible: !seriesLoading() && seriesList().length === 0" class="alert alert-info">
    No series yet.
    @if (isAdmin)
    {
        <text>Click "Create Series" to group playlists into a series (e.g. a course or multi-part collection).</text>
    }
</div>

<div data-bind="visible: !seriesLoading() && seriesList().length > 0" class="row g-3">
    <!-- ko foreach: seriesList -->
    <div class="col-xl-2 col-lg-3 col-md-4 col-sm-6">
        <div class="card h-100 series-tab-card position-relative">
            <!-- Collage thumbnail: always 4 cells, built by buildCollage() in the viewmodel -->
            <div class="position-relative">
                <a data-bind="attr: { href: '/series/' + id }" class="text-decoration-none d-block">
                    <div class="series-collage" data-bind="foreach: collageImages">
                        <!-- ko if: $data -->
                        <img data-bind="attr: { src: $data }" class="series-collage-img" loading="lazy" />
                        <!-- /ko -->
                        <!-- ko ifnot: $data -->
                        <div class="series-collage-placeholder bg-secondary"></div>
                        <!-- /ko -->
                    </div>
                </a>
            </div>

            <div class="card-body p-2">
                <a data-bind="attr: { href: '/series/' + id }, text: name"
                   class="text-decoration-none fw-semibold text-body card-title d-block mb-1 text-truncate"></a>
                <small class="text-muted">
                    <span data-bind="text: playlists.length"></span>
                    <span data-bind="text: playlists.length === 1 ? ' playlist' : ' playlists'"></span>
                </small>
            </div>
            @if (isAdmin)
            {
                <div class="channel-card-menu-wrap">
                    <div class="dropdown dropend">
                        <button type="button"
                                class="channel-card-menu-trigger"
                                data-bs-toggle="dropdown"
                                data-bs-boundary="viewport" data-bs-popper-config='{"strategy":"fixed"}'
                                aria-expanded="false"
                                aria-label="Series actions"
                                onclick="event.preventDefault(); event.stopPropagation();">
                            <i class="bi bi-three-dots-vertical" aria-hidden="true"></i>
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end shadow">
                            <li>
                                <button type="button" class="dropdown-item"
                                        data-bind="click: $parent.openEditSeries">
                                    <i class="bi bi-pencil me-2"></i>Edit series
                                </button>
                            </li>
                            <li><hr class="dropdown-divider" /></li>
                            <li>
                                <button type="button" class="dropdown-item text-danger"
                                        data-bind="click: $parent.deleteSeries">
                                    <i class="bi bi-trash me-2"></i>Delete series
                                </button>
                            </li>
                        </ul>
                    </div>
                </div>
            }
        </div>
    </div>
    <!-- /ko -->
</div>
