@* Shared by Videos/Details and DetailsCustom; Tagify targets #videoTagsInput *@
<div class="card mb-3">
    <div class="card-header py-2">
        <h6 class="mb-0"><i class="bi bi-tags"></i> Tags</h6>
    </div>
    <div class="card-body py-2">
        <input id="videoTagsInput" class="form-control form-control-sm" placeholder="Add tags..." />
        <div class="form-text">Press Enter or comma to add a tag. Changes are saved automatically.</div>
    </div>
</div>
