@{
    ViewData["Title"] = "Videos";
}

@section Styles {
    <link rel="stylesheet" href="~/css/video-index.css" />
}

<div class="container-fluid">
    <div class="row mb-3 align-items-center">
        <div class="col">
            <h2>Videos</h2>
            <p class="text-muted mb-0">All your archived videos</p>
        </div>
        <div class="col-auto">
            <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addVideoModal">
                <i class="bi bi-plus-circle"></i> Add Video
            </button>
        </div>
    </div>

    <!-- Filters -->
    <div class="row g-2 mb-4">
        <div class="col-12 col-md-4">
            <input type="text" class="form-control" placeholder="Search by title..."
                   data-bind="value: searchQuery, valueUpdate: 'afterkeydown'" />
        </div>
        <div class="col-12 col-md-3">
            <select class="form-select" data-bind="value: selectedChannelId, options: channels,
                optionsText: 'name', optionsValue: 'id', optionsCaption: 'All Channels'">
            </select>
        </div>
        <div class="col-12 col-md-4">
            <input id="tagFilterInput" class="form-control" placeholder="Filter by tags..." />
        </div>
        <div class="col-12 col-md-1">
            <button class="btn btn-outline-secondary w-100" data-bind="click: clearFilters" title="Clear filters">
                <i class="bi bi-x-circle"></i>
            </button>
        </div>
    </div>

    <!-- Loading -->
    <div data-bind="visible: loading" class="text-center py-5">
        <div class="spinner-border" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>

    <!-- Empty state -->
    <div data-bind="visible: !loading() && videos().length === 0" class="alert alert-info">
        <i class="bi bi-info-circle me-2"></i>
        No videos found. Use <strong>Add Video</strong> to archive standalone videos, or subscribe to a channel.
    </div>

    <!-- Video grid -->
    <div data-bind="visible: !loading() && videos().length > 0">
        <div class="row row-cols-2 row-cols-sm-3 row-cols-md-4 row-cols-lg-6 g-3">
            <!-- ko foreach: videos -->
            <div class="col">
                <div class="card h-100 video-card position-relative" data-bind="click: $parent.openVideo">
                    <div class="video-thumb-wrap">
                        <!-- ko if: thumbnailUrl -->
                        <img class="card-img-top video-thumb"
                             data-bind="attr: { src: thumbnailUrl, alt: title }" />
                        <!-- /ko -->
                        <!-- ko ifnot: thumbnailUrl -->
                        <div class="video-thumb-placeholder d-flex align-items-center justify-content-center bg-secondary text-white">
                            <i class="bi bi-play-circle fs-1"></i>
                        </div>
                        <!-- /ko -->
                        <!-- ko if: duration -->
                        <span class="badge bg-dark video-duration"
                              data-bind="text: $parent.formatDuration(duration)"></span>
                        <!-- /ko -->
                        <!-- ko if: downloadFailed -->
                        <span class="badge bg-danger video-status" title="Download failed">
                            <i class="bi bi-exclamation-triangle-fill"></i> Failed
                        </span>
                        <!-- /ko -->
                        <!-- ko if: !downloadFailed && !downloadedAt -->
                        <span class="badge bg-warning text-dark video-status" title="Downloading...">
                            <i class="bi bi-hourglass-split"></i>
                        </span>
                        <!-- /ko -->
                    </div>
                    <div class="card-body p-2">
                        <button type="button"
                                class="btn btn-sm btn-outline-danger position-absolute top-0 end-0 m-1"
                                title="Delete file"
                                data-bind="click: function(data, event) { $parent.deleteVideoFile(data, event); }">
                            <i class="bi bi-trash"></i>
                        </button>
                        <p class="card-text video-title fw-semibold"
                           data-bind="text: title" title=""></p>
                        <p class="card-text text-muted small mb-1"
                           data-bind="text: channel && channel.name"></p>
                        <!-- ko if: tags && tags.length > 0 -->
                        <div class="video-tags">
                            <!-- ko foreach: tags -->
                            <span class="badge rounded-pill bg-light text-dark border me-1 mb-1"
                                  data-bind="text: $data"></span>
                            <!-- /ko -->
                        </div>
                        <!-- /ko -->
                    </div>
                </div>
            </div>
            <!-- /ko -->
        </div>

        <!-- Pager -->
        @await Html.PartialAsync("_Pager", new MyVideoArchive.Models.PagerViewModel(
            "Videos pagination",
            "currentPage", "totalPages", "totalCount", "pageNumbers",
            "previousPage", "nextPage", "goToPage",
            "videos"))
    </div>
</div>

<!-- Add Video Modal -->
<div class="modal fade" id="addVideoModal" tabindex="-1" aria-labelledby="addVideoModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="addVideoModalLabel">Add Standalone Video</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p class="text-muted small">
                    Paste a video URL to archive it. The video will be tagged
                    <strong>standalone</strong> so you can find it easily. If you later subscribe
                    to that channel, the tag will be removed automatically.
                </p>
                <div class="mb-3">
                    <label for="standaloneVideoUrl" class="form-label">Video URL</label>
                    <input type="url" class="form-control" id="standaloneVideoUrl"
                           data-bind="value: newVideoUrl"
                           placeholder="https://www.youtube.com/watch?v=... or https://www.bitchute.com/video/..." />
                </div>
                <div data-bind="visible: addVideoError, text: addVideoError" class="alert alert-danger py-2 small"></div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary"
                        data-bind="click: addStandaloneVideo, enable: newVideoUrl().length > 0 && !addingVideo()">
                    <span data-bind="visible: !addingVideo()">
                        <i class="bi bi-download"></i> Add &amp; Download
                    </span>
                    <span data-bind="visible: addingVideo()">
                        <span class="spinner-border spinner-border-sm"></span> Fetching metadata...
                    </span>
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script type="module" src="~/js/video-index.js"></script>
}
