{
  "SeedAdmin": {
    "Email": "admin@myvideoarchive.local"
    // "Password": "Admin@123"   ← override here or via SeedAdmin__Password env var
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Hangfire": "Information"
    }
  },
  "AllowedHosts": "*",
  "VideoDownload": {
    "OutputPath": "D:\\Videos\\MyVideoArchive",
    //"VideoQuality": "bestvideo[ext=mp4]+bestaudio[ext=m4a]/best[ext=mp4]/best"
    "VideoQuality": "bestvideo[height=720]+bestaudio/bestvideo[height=720]+bestaudio/bestvideo[height=480]+bestaudio/best",
    "Throttle": {
      "MinDelaySeconds": 10,
      "MaxDelaySeconds": 60,
      "BatchSize": 25,
      "BatchWindowMinutes": 30
    }
  },
  "YoutubeDL": {
    "ExecutablePath": null,
    "FFmpegPath": null
  }

  // ── Optional: Keycloak authentication ──────────────────────────────────────
  // By default the app uses built-in ASP.NET Core Identity (local user database).
  // To use Keycloak instead, uncomment the block below and fill in your values.
  // See docs/KEYCLOAK_SETUP.md for step-by-step Keycloak configuration instructions.
  //
  // "Authentication": {
  //   "Provider": "Keycloak",
  //   "Keycloak": {
  //     // Authority: public Keycloak realm URL — used by the browser for login AND by the
  //     // app container for backchannel calls (discovery, token exchange).
  //     // The container must be able to reach this URL; use extra_hosts in docker-compose
  //     // when Keycloak is in a separate stack behind a reverse proxy (see docker-compose.yml).
  //     // Format: http(s)://<host>:<port>/realms/<realm-name>
  //     "Authority": "http://localhost:8081/realms/myvideoarchive",
  //
  //     // ClientId must match the client you created in Keycloak.
  //     "ClientId": "myvideoarchive",
  //
  //     // ClientSecret: copy from Keycloak → Clients → myvideoarchive → Credentials tab.
  //     // Never commit this value. Use User Secrets (dev) or an environment variable (prod).
  //     "ClientSecret": "replace-with-your-client-secret"
  //
  //     // Optional: Keycloak Admin API credentials used for looking up user details.
  //     // The client must have a service account with the realm-management → view-users role.
  //     // If omitted, falls back to ClientId/ClientSecret above (if that client has a service account).
  //     // "AdminClientId": "myvideoarchive-admin",
  //     // "AdminClientSecret": "replace-with-admin-client-secret",
  //
  //     // Optional: set to the app's public HTTPS URL (e.g. https://mva.example.com) when the
  //     // reverse proxy does not forward X-Forwarded-Proto and the app sends http:// in redirect_uri.
  //     // Not needed if forwarded headers are working correctly.
  //     // "PublicOrigin": "https://mva.example.com",
  //
  //     // Optional: when the app container cannot reach the public Keycloak hostname (e.g.
  //     // Docker hairpin NAT), set this to the internal URL where the container can reach
  //     // Keycloak directly. All backchannel calls (discovery, token exchange) are rerouted
  //     // there while Authority stays public for browser-facing login redirects.
  //     // Example (same Docker network, using container name): "http://keycloak:8080"
  //     // "BackchannelBaseUrl": "http://keycloak:8080"
  //   }
  // }
}
