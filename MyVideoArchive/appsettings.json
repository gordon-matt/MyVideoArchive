{
  "SeedAdmin": {
    "Email": "admin@myvideoarchive.local"
    // "Password": "Admin@123"   ← override here or via SeedAdmin__Password env var
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Hangfire": "Information"
    }
  },
  "AllowedHosts": "*",
  "VideoDownload": {
    "OutputPath": "D:\\Videos\\MyVideoArchive",
    //"VideoQuality": "bestvideo[ext=mp4]+bestaudio[ext=m4a]/best[ext=mp4]/best"
    "VideoQuality": "bestvideo[height=720]+bestaudio/bestvideo[height=720]+bestaudio/bestvideo[height=480]+bestaudio/best",
    "Throttle": {
      "MinDelaySeconds": 10,
      "MaxDelaySeconds": 60,
      "BatchSize": 25,
      "BatchWindowMinutes": 30
    }
  },
  "YoutubeDL": {
    "ExecutablePath": null,
    "FFmpegPath": null
  }

  // ── Optional: Keycloak authentication ──────────────────────────────────────
  // By default the app uses built-in ASP.NET Core Identity (local user database).
  // To use Keycloak instead, uncomment the block below and fill in your values.
  // See docs/KEYCLOAK_SETUP.md for step-by-step Keycloak configuration instructions.
  //
  // "Authentication": {
  //   "Provider": "Keycloak",
  //   "Keycloak": {
  //     // Authority = the URL of your Keycloak realm.
  //     // Format: http(s)://<host>:<port>/realms/<realm-name>
  //     "Authority": "http://localhost:8081/realms/myvideoarchive",
  //
  //     // ClientId must match the client you created in Keycloak.
  //     "ClientId": "myvideoarchive",
  //
  //     // ClientSecret: copy from Keycloak → Clients → myvideoarchive → Credentials tab.
  //     // Store in User Secrets (dev) or an environment variable (prod) — not in source control.
  //     "ClientSecret": "replace-with-your-client-secret"
  //   }
  // }
}
